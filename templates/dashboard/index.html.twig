{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}

<div class="container-fluid py-4">

    {# ===================== EN-TÊTE ===================== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="h2 fw-bold text-primary mb-1">
                <i class="bi bi-speedometer2 me-2"></i>
                Tableau de bord
            </h1>

            <p class="text-muted mb-0">
                Vue d’ensemble des dossiers d’équivalence académique.
            </p>
        </div>

        <div>
            <span class="badge bg-light text-dark border px-3 py-2">
                <i class="bi bi-calendar-check me-1"></i>
                {{ "now"|date("d/m/Y H:i") }}
            </span>
        </div>

    </div>

    {# ===================== STATISTIQUES ===================== #}
    <div class="row g-4 mb-4">

        {# TOTAL DOSSIERS #}
        <div class="col-xl-4 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Total des dossiers
                            </div>

                            <div class="display-5 fw-bold text-dark">
                                {{ total|default(0) }}
                            </div>

                        </div>

                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                            <i class="bi bi-folder2-open fs-3"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        {# DOSSIERS ACCEPTÉS #}
        <div class="col-xl-4 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Dossiers approuvés
                            </div>

                            <div class="display-5 fw-bold text-success">
                                {{ approved|default(0) }}
                            </div>

                        </div>

                        <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                            <i class="bi bi-check-circle-fill fs-3"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        {# DOSSIERS REFUSÉS #}
        <div class="col-xl-4 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Dossiers refusés
                            </div>

                            <div class="display-5 fw-bold text-danger">
                                {{ rejected|default(0) }}
                            </div>

                        </div>

                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3">
                            <i class="bi bi-x-circle-fill fs-3"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    {# ===================== INFORMATIONS ===================== #}
    <div class="row g-4">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-light py-3 border-0">
                    <h2 class="h5 fw-bold mb-0">
                        <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>
                        Synthèse des activités
                    </h2>
                </div>

                <div class="card-body">

                    <div class="row text-center g-4">

                        <div class="col-md-4">
                            <div class="border rounded-4 p-3 h-100">

                                <div class="text-primary mb-2">
                                    <i class="bi bi-folder-fill fs-1"></i>
                                </div>

                                <h3 class="h4 fw-bold mb-1">
                                    {{ total|default(0) }}
                                </h3>

                                <p class="text-muted small mb-0">
                                    Dossiers enregistrés
                                </p>

                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded-4 p-3 h-100">

                                <div class="text-success mb-2">
                                    <i class="bi bi-patch-check-fill fs-1"></i>
                                </div>

                                <h3 class="h4 fw-bold mb-1">
                                    {{ approved|default(0) }}
                                </h3>

                                <p class="text-muted small mb-0">
                                    Décisions favorables
                                </p>

                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded-4 p-3 h-100">

                                <div class="text-danger mb-2">
                                    <i class="bi bi-shield-x fs-1"></i>
                                </div>

                                <h3 class="h4 fw-bold mb-1">
                                    {{ rejected|default(0) }}
                                </h3>

                                <p class="text-muted small mb-0">
                                    Décisions défavorables
                                </p>

                            </div>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        {# ===================== SIDEBAR ===================== #}
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

                <div class="card-header bg-light py-3 border-0">
                    <h2 class="h5 fw-bold mb-0">
                        <i class="bi bi-info-circle-fill text-primary me-2"></i>
                        Informations
                    </h2>
                </div>

                <div class="card-body">

                    <div class="d-flex align-items-start mb-4">

                        <div class="me-3 text-primary">
                            <i class="bi bi-diagram-3-fill fs-4"></i>
                        </div>

                        <div>
                            <h6 class="fw-bold mb-1">
                                Circuit de traitement
                            </h6>

                            <p class="small text-muted mb-0">
                                Les dossiers suivent un processus structuré :
                                dépôt, analyse, comité et décision finale.
                            </p>
                        </div>

                    </div>

                    <hr>

                    <div class="d-flex align-items-start mb-4">

                        <div class="me-3 text-success">
                            <i class="bi bi-shield-lock-fill fs-4"></i>
                        </div>

                        <div>
                            <h6 class="fw-bold mb-1">
                                Sécurité des données
                            </h6>

                            <p class="small text-muted mb-0">
                                Toutes les opérations sont protégées par les
                                mécanismes de sécurité Symfony et les validations système.
                            </p>
                        </div>

                    </div>

                    <hr>

                    <div class="d-flex align-items-start">

                        <div class="me-3 text-warning">
                            <i class="bi bi-clock-history fs-4"></i>
                        </div>

                        <div>
                            <h6 class="fw-bold mb-1">
                                Suivi en temps réel
                            </h6>

                            <p class="small text-muted mb-0">
                                Les statistiques affichées sont mises à jour automatiquement.
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
