{% extends 'base.html.twig' %}

{% block title %}Validation des diplômes | Commission
{% endblock %}


{% block body %}
<div class="container-fluid px-4 py-4">
	<div class="row mb-4">
		<div class="col">
			<h1 class="h2 fw-bold text-primary">
				<i class="bi bi-mortarboard-fill me-2"></i>Validation des diplômes
			</h1>
			<p class="text-muted">
				Diplômes proposés par les établissements, en attente d’approbation ou de rejet.
			</p>
		</div>
	</div>


<div class="card shadow-sm border-0 rounded-4">
	<div class="card-header bg-white border-bottom-0 pt-4 pb-0">
		<div class="d-flex justify-content-between align-items-center">
			<h5 class="card-title mb-0 fw-semibold">
				<i class="bi bi-list-check me-2 text-primary"></i>Liste des demandes
			</h5>
			<span class="badge bg-primary rounded-pill px-3 py-2">
				{{ pending|length }}
				diplôme(s) en attente
			</span>
		</div>
	</div>
	<div class="card-body p-0">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="table-light">
					<tr></tr>
				</thead>

<th scope="col">Titre du diplôme</th>
<th scope="col">Établissement source</th>
<th scope="col">Proposé par</th>
<th scope="col" class="text-end">Actions</th></tr></thead><tbody>{% for diplome in pending %}
<tr></tr>

<td>
	<div class="fw-semibold">{{ diplome.titre|e }}</div>
	{% if diplome.etablissementSource is defined and diplome.etablissementSource %}
		<div class="small text-muted">{{ diplome.etablissementSource.nom|e }}</div>
	{% endif %}
</td>
<td>
	{{ diplome.etablissementSource ? diplome.etablissementSource.nom|e : '—' }}
</td>
<td>
	{% if diplome.proposedBy %}

<div class="d-flex align-items-center gap-2">
	<i class="bi bi-envelope-at text-secondary"></i>
	{{ diplome.proposedBy.email|e }}
</div>{% else %}
<span class="text-muted">—</span>{% endif %}</td>

<td class="text-end">
	<div class="btn-group" role="group">
		<form method="post" action="{{ path('commission_diplome_approve', {id: diplome.id}) }}" class="d-inline-block me-1">
			<input type="hidden" name="_token" value="{{ csrf_token('approve_diplome_' ~ diplome.id) }}">

<button type="submit" class="btn btn-sm btn-success rounded-pill px-3" title="Approuver">
	<i class="bi bi-check-lg me-1"></i>Approuver
</button></form>

<form method="post" action="{{ path('commission_diplome_reject', {id: diplome.id}) }}" class="d-inline-block me-1">
	<input type="hidden" name="_token" value="{{ csrf_token('reject_diplome_' ~ diplome.id) }}">

<button type="submit" class="btn btn-sm btn-danger rounded-pill px-3" title="Rejeter">
	<i class="bi bi-x-lg me-1"></i>Rejeter
</button></form>

<a href="{{ path('commission_regle_new', {id: diplome.id}) }}" class="btn btn-sm btn-info rounded-pill px-3" title="Créer une règle">
	<i class="bi bi-diagram-3 me-1"></i>Règle
</a></div></td></tr>{% else %}<tr></tr>

<td colspan="4" class="text-center py-5">
	<div class="text-muted">
		<i class="bi bi-archive display-6 d-block mb-3"></i>
		<h6 class="fw-semibold">Aucun diplôme en attente</h6>
		<p class="small mb-0">Tous les diplômes proposés ont été traités ou aucun établissement n’a encore soumis de demande.</p>
	</div>
</td></tr>{% endfor %}</tbody></table>

</div></div></div>

</div>
{% endblock %}
