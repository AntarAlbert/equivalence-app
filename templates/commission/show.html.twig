{# templates/commission/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
    Commission — Dossier {{ equivalence.numeroDossier|e }}
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ========================================================= #}
    {# HEADER #}
    {# ========================================================= #}

    {% set statusConfig = {
        'submitted': {
            color: 'primary',
            icon: 'bi-send-check',
            label: 'Soumis'
        },
        'in_review': {
            color: 'warning',
            icon: 'bi-search',
            label: 'En analyse'
        },
        'in_committee': {
            color: 'info',
            icon: 'bi-people',
            label: 'En commission'
        },
        'approved': {
            color: 'success',
            icon: 'bi-check-circle',
            label: 'Approuvé'
        },
        'rejected': {
            color: 'danger',
            icon: 'bi-x-circle',
            label: 'Rejeté'
        }
    } %}

    {% set currentStatus = statusConfig[equivalence.status]|default({
        color: 'secondary',
        icon: 'bi-question-circle',
        label: equivalence.status|replace({'_':' '})|capitalize
    }) %}

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="card-body p-4">

            <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-4">

                <div class="d-flex align-items-start gap-3">

                    <div class="icon-wrapper bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-folder2-open"></i>
                    </div>

                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">

                            <h1 class="h3 fw-bold mb-0">
                                Dossier n°
                                {{ equivalence.numeroDossier|e }}
                            </h1>

                            <span class="badge bg-{{ currentStatus.color }} rounded-pill px-3 py-2">
                                <i class="bi {{ currentStatus.icon }} me-1"></i>
                                {{ currentStatus.label }}
                            </span>

                        </div>

                        <div class="text-muted mb-2">
                            Commission d’équivalence administrative
                        </div>

                        <div class="d-flex flex-wrap gap-3 small text-muted">

                            <span>
                                <i class="bi bi-person me-1"></i>
                                {{ equivalence.nom|e }}
                                {{ equivalence.prenom|e }}
                            </span>

                            <span>
                                <i class="bi bi-envelope me-1"></i>
                                {{ equivalence.email|default('—')|e }}
                            </span>

                            <span>
                                <i class="bi bi-calendar-event me-1"></i>
                                Créé le
                                {{ equivalence.createdAt|date('d/m/Y H:i') }}
                            </span>

                        </div>
                    </div>

                </div>

                <div class="d-flex flex-wrap gap-2">

                    <a href="{{ path('commission_dashboard') }}"
                       class="btn btn-light border rounded-pill px-4">
                        <i class="bi bi-arrow-left-circle me-1"></i>
                        Retour
                    </a>

                    {# Vérifier si l'arrêté existe – la relation est 'arrete' dans Equivalence #}
                    {% if equivalence.arrete %}
                        <a href="{{ path('admin_arrete_show', { id: equivalence.arrete.id }) }}"
                           class="btn btn-danger rounded-pill px-4 shadow-sm">
                            <i class="bi bi-file-earmark-pdf me-1"></i>
                            Arrêté
                        </a>
                    {% endif %}

                </div>

            </div>

        </div>
    </div>

    <div class="row g-4">

        {# ========================================================= #}
        {# LEFT COLUMN #}
        {# ========================================================= #}

        <div class="col-xl-8">

            {# ========================================================= #}
            {# CANDIDAT #}
            {# ========================================================= #}

            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">

                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex align-items-center">

                        <div class="icon-sm bg-primary bg-opacity-10 text-primary me-3">
                            <i class="bi bi-person-vcard"></i>
                        </div>

                        <div>
                            <h5 class="fw-bold mb-0">
                                Informations du candidat
                            </h5>
                            <small class="text-muted">
                                Données administratives et identité
                            </small>
                        </div>

                    </div>
                </div>

                <div class="card-body p-4">

                    <div class="row g-4">

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Nom complet
                                </div>
                                <div class="info-value">
                                    {{ equivalence.nom|e }}
                                    {{ equivalence.prenom|e }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Nationalité
                                </div>
                                <div class="info-value">
                                    {{ equivalence.nationalite ? equivalence.nationalite.nomFrFr|e : '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Date de naissance
                                </div>
                                <div class="info-value">
                                    {{ equivalence.dateNaissance ? equivalence.dateNaissance|date('d/m/Y') : '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Numéro CNI
                                </div>
                                <div class="info-value">
                                    {{ equivalence.cni|default('—')|e }}
                                </div>
                            </div>
                        </div>

                    </div>

                    {% if equivalence.observation %}
                        <div class="alert alert-light border mt-4 mb-0 rounded-4">

                            <div class="fw-semibold mb-2">
                                <i class="bi bi-chat-left-text me-1"></i>
                                Observation
                            </div>

                            <div class="text-secondary">
                                {{ equivalence.observation|e|nl2br }}
                            </div>

                        </div>
                    {% endif %}

                </div>

            </div>

            {# ========================================================= #}
            {# DIPLOME & RÈGLE #}
            {# ========================================================= #}

            {% set diplome = equivalence.diplomeReference %}
            {% set regle = equivalence.regleAppliquee %}

            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">

                <div class="card-header bg-white border-0 py-3">

                    <div class="d-flex align-items-center">

                        <div class="icon-sm bg-success bg-opacity-10 text-success me-3">
                            <i class="bi bi-mortarboard"></i>
                        </div>

                        <div>
                            <h5 class="fw-bold mb-0">
                                Diplôme et équivalence
                            </h5>
                            <small class="text-muted">
                                Informations académiques
                            </small>
                        </div>

                    </div>

                </div>

                <div class="card-body p-4">

                    <div class="row g-4">

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Diplôme
                                </div>
                                <div class="info-value">
                                    {{ diplome ? diplome.titre|e : '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Établissement
                                </div>
                                <div class="info-value">
                                    {{ diplome and diplome.etablissement ? diplome.etablissement.nom|e : '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">
                                    Pays
                                </div>
                                <div class="info-value">
                                    {{ diplome and diplome.etablissement and diplome.etablissement.pays ? diplome.etablissement.pays.nomFrFr|e : '—' }}
                                </div>
                            </div>
                        </div>

                        {% if regle %}
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="info-label">
                                        Classement
                                    </div>
                                    <div class="info-value">
                                        {{ regle.classementComplet|e }}
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                    </div>

                    {% if regle and regle.texteReference %}
                        <div class="alert alert-light border rounded-4 mt-4 mb-0">

                            <div class="fw-semibold mb-2">
                                <i class="bi bi-journal-text me-1"></i>
                                Texte de référence
                            </div>

                            <div class="small text-secondary">
                                {{ regle.texteReference|e|nl2br }}
                            </div>

                        </div>
                    {% endif %}

                </div>

            </div>

            {# ========================================================= #}
            {# WORKFLOW ACTIONS #}
            {# ========================================================= #}

            {% if equivalence.status not in ['approved', 'rejected'] %}

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

                    <div class="card-header bg-primary text-white py-3 border-0">

                        <div class="d-flex align-items-center">
                            <i class="bi bi-sliders2 me-2"></i>
                            <h5 class="mb-0 fw-semibold">
                                Actions workflow
                            </h5>
                        </div>

                    </div>

                    <div class="card-body p-4">

                        <div class="d-flex flex-wrap gap-3">

                            {% if equivalence.status == 'submitted' %}

                                <form method="post"
                                      action="{{ path('commission_transition', { id: equivalence.id, transition: 'start_review' }) }}">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('transition_' ~ equivalence.id) }}">

                                    <button type="submit"
                                            class="btn btn-warning rounded-pill px-4">
                                        <i class="bi bi-search me-1"></i>
                                        Démarrer l’analyse
                                    </button>

                                </form>

                            {% elseif equivalence.status == 'in_review' %}

                                <form method="post"
                                      action="{{ path('commission_transition', { id: equivalence.id, transition: 'send_to_committee' }) }}">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('transition_' ~ equivalence.id) }}">

                                    <button type="submit"
                                            class="btn btn-info rounded-pill px-4">
                                        <i class="bi bi-people me-1"></i>
                                        Envoyer en commission
                                    </button>

                                </form>

                            {% elseif equivalence.status == 'in_committee' %}

                                <form method="post"
                                      action="{{ path('commission_transition', { id: equivalence.id, transition: 'approve' }) }}"
                                      onsubmit="return confirm('Confirmer l’approbation du dossier ?')">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('transition_' ~ equivalence.id) }}">

                                    <button type="submit"
                                            class="btn btn-success rounded-pill px-4">
                                        <i class="bi bi-check-circle me-1"></i>
                                        Approuver
                                    </button>

                                </form>

                                <form method="post"
                                      action="{{ path('commission_transition', { id: equivalence.id, transition: 'reject' }) }}"
                                      onsubmit="return confirm('Confirmer le rejet définitif ?')">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('transition_' ~ equivalence.id) }}">

                                    <button type="submit"
                                            class="btn btn-danger rounded-pill px-4">
                                        <i class="bi bi-x-circle me-1"></i>
                                        Rejeter
                                    </button>

                                </form>

                                <form method="post"
                                      action="{{ path('commission_transition', { id: equivalence.id, transition: 'ask_modification' }) }}">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('transition_' ~ equivalence.id) }}">

                                    <button type="submit"
                                            class="btn btn-secondary rounded-pill px-4">
                                        <i class="bi bi-arrow-repeat me-1"></i>
                                        Demander modification
                                    </button>

                                </form>

                            {% endif %}

                        </div>

                    </div>

                </div>

            {% endif %}

        </div>

        {# ========================================================= #}
        {# RIGHT COLUMN #}
        {# ========================================================= #}

        <div class="col-xl-4">

            {# DOCUMENTS #}

            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">

                <div class="card-header bg-white border-0 py-3">

                    <div class="d-flex align-items-center">

                        <div class="icon-sm bg-danger bg-opacity-10 text-danger me-3">
                            <i class="bi bi-files"></i>
                        </div>

                        <div>
                            <h5 class="fw-bold mb-0">
                                Documents joints
                            </h5>
                            <small class="text-muted">
                                Pièces justificatives
                            </small>
                        </div>

                    </div>

                </div>

                <div class="card-body p-3">

                    {% if equivalence.documents|length > 0 %}

                        <div class="d-flex flex-column gap-2">

                            {% for doc in equivalence.documents %}

                                <a href="{{ path('document_download', { id: doc.id }) }}"
                                   class="document-link text-decoration-none">

                                    <div class="d-flex align-items-center justify-content-between">

                                        <div class="d-flex align-items-center">

                                            <div class="doc-icon me-3">
                                                <i class="bi bi-file-earmark-{{ doc.mimeType == 'application/pdf' ? 'pdf' : 'image' }}"></i>
                                            </div>

                                            <div>
                                                <div class="fw-semibold text-dark small">
                                                    {{ doc.type|e }}
                                                </div>

                                                <div class="text-muted smaller">
                                                    {{ doc.originalName|e }}
                                                </div>
                                            </div>

                                        </div>

                                        <i class="bi bi-download text-muted"></i>

                                    </div>

                                </a>

                            {% endfor %}

                        </div>

                    {% else %}

                        <div class="text-center py-4">

                            <i class="bi bi-inbox display-6 text-muted"></i>

                            <div class="text-muted mt-2">
                                Aucun document
                            </div>

                        </div>

                    {% endif %}

                </div>

            </div>

            {# TIMELINE #}

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

                <div class="card-header bg-white border-0 py-3">

                    <div class="d-flex align-items-center">

                        <div class="icon-sm bg-info bg-opacity-10 text-info me-3">
                            <i class="bi bi-clock-history"></i>
                        </div>

                        <div>
                            <h5 class="fw-bold mb-0">
                                Workflow
                            </h5>
                            <small class="text-muted">
                                Cycle de traitement
                            </small>
                        </div>

                    </div>

                </div>

                <div class="card-body p-4">

                    <div class="timeline">

                        <div class="timeline-item active">
                            <div class="timeline-dot"></div>
                            <div>
                                <div class="fw-semibold">
                                    Soumission
                                </div>
                                <small class="text-muted">
                                    Dossier enregistré
                                </small>
                            </div>
                        </div>

                        <div class="timeline-item {{ equivalence.status in ['in_review','in_committee','approved','rejected'] ? 'active' : '' }}">
                            <div class="timeline-dot"></div>
                            <div>
                                <div class="fw-semibold">
                                    Analyse
                                </div>
                                <small class="text-muted">
                                    Vérification administrative
                                </small>
                            </div>
                        </div>

                        <div class="timeline-item {{ equivalence.status in ['in_committee','approved','rejected'] ? 'active' : '' }}">
                            <div class="timeline-dot"></div>
                            <div>
                                <div class="fw-semibold">
                                    Commission
                                </div>
                                <small class="text-muted">
                                    Étude du dossier
                                </small>
                            </div>
                        </div>

                        <div class="timeline-item {{ equivalence.status in ['approved','rejected'] ? 'active' : '' }}">
                            <div class="timeline-dot"></div>
                            <div>
                                <div class="fw-semibold">
                                    Décision finale
                                </div>
                                <small class="text-muted">
                                    Validation ou rejet
                                </small>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .icon-wrapper{
        width:70px;
        height:70px;
        border-radius:20px;
        display:flex;
        align-items:center;
        justify-content:center;
        font-size:1.8rem;
    }

    .icon-sm{
        width:42px;
        height:42px;
        border-radius:12px;
        display:flex;
        align-items:center;
        justify-content:center;
        font-size:1rem;
    }

    .info-card{
        background:#f8fafc;
        border-radius:16px;
        padding:1rem;
        height:100%;
        border:1px solid #edf2f7;
    }

    .info-label{
        font-size:.8rem;
        color:#6c757d;
        margin-bottom:.35rem;
    }

    .info-value{
        font-weight:600;
        color:#212529;
    }

    .document-link{
        border:1px solid #edf2f7;
        border-radius:16px;
        padding:1rem;
        transition:all .2s ease;
        background:#fff;
    }

    .document-link:hover{
        transform:translateY(-2px);
        box-shadow:0 .5rem 1rem rgba(0,0,0,.08);
        border-color:#dbe4ff;
    }

    .doc-icon{
        width:42px;
        height:42px;
        border-radius:12px;
        background:#f8f9fa;
        display:flex;
        align-items:center;
        justify-content:center;
        font-size:1.2rem;
        color:#0d6efd;
    }

    .timeline{
        position:relative;
    }

    .timeline::before{
        content:'';
        position:absolute;
        top:0;
        left:9px;
        width:2px;
        height:100%;
        background:#dee2e6;
    }

    .timeline-item{
        position:relative;
        padding-left:2rem;
        margin-bottom:1.5rem;
    }

    .timeline-item:last-child{
        margin-bottom:0;
    }

    .timeline-dot{
        position:absolute;
        left:0;
        top:4px;
        width:20px;
        height:20px;
        border-radius:50%;
        background:#dee2e6;
        border:4px solid #fff;
        box-shadow:0 0 0 2px #dee2e6;
    }

    .timeline-item.active .timeline-dot{
        background:#0d6efd;
        box-shadow:0 0 0 2px #0d6efd;
    }

    .smaller{
        font-size:.75rem;
    }

    .card{
        transition:all .2s ease;
    }

    .card:hover{
        transform:translateY(-2px);
    }

</style>

{% endblock %}
