{% extends 'base.html.twig' %}

{% block title %}Mes diplômes proposés{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="h2 fw-bold text-primary">
                <i class="bi bi-award me-2"></i>Diplômes proposés
            </h1>
            <p class="text-muted">Liste des diplômes soumis par votre établissement à la commission.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a href="{{ path('etablissement_diplome_new') }}" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-1"></i> Proposer un diplôme
            </a>
        </div>
    </div>

    {# Barre de recherche #}
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-10">
                    <label for="search" class="visually-hidden">Rechercher</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" id="search" class="form-control"
                               placeholder="Rechercher par titre ou établissement…"
                               value="{{ app.request.query.get('search')|e }}">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100">Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    {# Tableau des diplômes #}
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><i class="bi bi-mortarboard me-1"></i> Titre</th>
                            <th><i class="bi bi-building me-1"></i> Établissement</th>
                            <th><i class="bi bi-check-circle me-1"></i> Statut</th>
                            <th class="text-end"><i class="bi bi-gear me-1"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for diplome in diplomes %}
                            <tr>
                                <td class="fw-semibold">{{ diplome.titre|e }}</td>
                                <td>{{ diplome.etablissement ? diplome.etablissement.nom|e : '—' }}</td>
                                <td>
                                    {% set status = diplome.validationStatus %}
                                    {% set statusClass = {
                                        'pending': 'warning',
                                        'approved': 'success',
                                        'rejected': 'danger'
                                    }[status]|default('secondary') %}
                                    <span class="badge bg-{{ statusClass }} rounded-pill px-3 py-2">
                                        <i class="bi {{ status == 'pending' ? 'bi-hourglass-split' : (status == 'approved' ? 'bi-check-circle-fill' : 'bi-x-circle-fill') }} me-1"></i>
                                        {{ status == 'pending' ? 'En attente' : (status == 'approved' ? 'Approuvé' : 'Rejeté') }}
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        {% if diplome.validationStatus == 'pending' %}
                                            <a href="{{ path('etablissement_diplome_edit', {id: diplome.id}) }}"
                                               class="btn btn-sm btn-outline-warning rounded-pill me-1" title="Modifier">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                        {% endif %}
                                        <a href="{{ path('etablissement_diplome_show', {id: diplome.id}) }}"
                                           class="btn btn-sm btn-outline-info rounded-pill" title="Voir">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <i class="bi bi-inbox display-6 d-block mb-3 text-muted"></i>
                                    <h5 class="fw-semibold text-muted">Aucun diplôme proposé</h5>
                                    <p class="text-muted mb-0">Votre établissement n’a encore soumis aucun diplôme à la commission.</p>
                                    <a href="{{ path('etablissement_diplome_new') }}" class="btn btn-sm btn-primary mt-3">Proposer un diplôme</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Pagination #}
    {% if diplomes is defined and diplomes.getPaginationData is defined %}
        <div class="mt-4 d-flex justify-content-center">
            {{ knp_pagination_render(diplomes) }}
        </div>
    {% endif %}
</div>
{% endblock %}
