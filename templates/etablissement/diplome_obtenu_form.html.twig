{% extends 'base.html.twig' %}

{% block title %}Ajouter un diplômé{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Ajouter un diplômé à la liste officielle</h1>
    {{ form_start(form) }}
        {{ form_row(form.diplome) }}
        {{ form_row(form.nom) }}
        {{ form_row(form.prenom) }}
        {{ form_row(form.numeroCni) }}
        {{ form_row(form.anneeObtention) }}
        {{ form_row(form.numeroDiplome) }}
        {{ form_row(form.mention) }}
        {{ form_row(form.moyenne) }}
        <button type="submit" class="btn btn-success">Enregistrer</button>
    {{ form_end(form) }}
</div>
{% endblock %}
