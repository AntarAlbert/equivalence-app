{{ form_start(form, { attr: { novalidate: 'novalidate', class: 'needs-validation' } }) }}

{# Erreurs globales #}
{% if form.vars.errors|length > 0 %}
    <div class="alert alert-danger rounded-4 mb-4">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        {{ form_errors(form) }}
    </div>
{% endif %}

{# Identité #}
<section class="mb-5">
    <div class="d-flex gap-2 align-items-center mb-3">
        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2"><i class="bi bi-person"></i></div>
        <h3 class="h5 fw-bold mb-0">Identité du candidat</h3>
    </div>
    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.nom, { attr: { class: 'form-control', maxlength: 100 } }) }}</div>
        <div class="col-md-6">{{ form_row(form.prenom, { attr: { class: 'form-control', maxlength: 100 } }) }}</div>
        <div class="col-md-6">{{ form_row(form.dateNaissance) }}</div>
        <div class="col-md-6">{{ form_row(form.lieuNaissance) }}</div>
    </div>
</section>

{# Infos complémentaires #}
<section class="mb-5">
    <div class="d-flex gap-2 align-items-center mb-3">
        <div class="bg-info bg-opacity-10 text-info rounded-circle p-2"><i class="bi bi-envelope-paper"></i></div>
        <h3 class="h5 fw-bold mb-0">Informations complémentaires</h3>
    </div>
    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.email) }}</div>
        <div class="col-md-6">{{ form_row(form.nationalite) }}</div>
        <div class="col-md-6">{{ form_row(form.emploi) }}</div>
        <div class="col-md-6" id="matricule-field" style="display: none;">{{ form_row(form.matricule) }}</div>
    </div>

    {# Détails CNI (majeur) #}
    <div id="cin-detail-section" class="mt-4" style="display: none;">
        <div class="bg-light rounded-4 p-4 border">
            <div class="d-flex gap-2 align-items-center mb-3">
                <i class="bi bi-card-text fs-5"></i>
                <h4 class="h6 fw-bold mb-0">Détails de la CNI</h4>
            </div>
            <div class="row g-3">
                <div class="col-md-6">{{ form_row(form.cni, { attr: { class: 'form-control', 'data-mask': 'cni', placeholder: '123 456 789 012' } }) }}</div>
                <div class="col-md-6">{{ form_row(form.cniDateDelivrance) }}</div>
                <div class="col-md-6">{{ form_row(form.cniLieuDelivrance) }}</div>
                <div class="col-md-6">{{ form_row(form.cniDateDuplicata) }}</div>
                <div class="col-md-6">{{ form_row(form.cniLieuDuplicata) }}</div>
            </div>
        </div>
    </div>
</section>

{# Diplôme de référence #}
<section class="mb-5">
    <div class="d-flex gap-2 align-items-center mb-3">
        <div class="bg-success bg-opacity-10 text-success rounded-circle p-2"><i class="bi bi-mortarboard"></i></div>
        <h3 class="h5 fw-bold mb-0">Diplôme de référence</h3>
    </div>
    {{ form_row(form.diplomeReference) }}
    <div class="row g-3 mt-2">
        <div class="col-md-6">{{ form_row(form.universite, { attr: { readonly: true, class: 'form-control bg-light' } }) }}</div>
        <div class="col-md-6">{{ form_row(form.pays, { attr: { readonly: true, class: 'form-control bg-light' } }) }}</div>
    </div>
</section>

{# Documents #}
<section class="mb-5">
    <div class="d-flex gap-2 align-items-center mb-3">
        <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-2"><i class="bi bi-file-earmark-arrow-up"></i></div>
        <h3 class="h5 fw-bold mb-0">Documents obligatoires</h3>
    </div>

    {# Afficher les documents existants en édition #}
    {% if equivalence is defined and equivalence.documents|length > 0 %}
        <div class="mb-4">
            <h4 class="h6 fw-semibold">Documents actuels</h4>
            <div class="row g-3">
                {% for doc in equivalence.documents %}
                    <div class="col-md-4">
                        <div class="border rounded-4 p-2 bg-light">
                            <div class="small fw-semibold">
                                {% if doc.type == 'DIPLOME' %}<i class="bi bi-mortarboard text-primary"></i> Diplôme
                                {% elseif doc.type == 'RELEVE' %}<i class="bi bi-journal-text text-success"></i> Relevé
                                {% else %}<i class="bi bi-person-vcard text-warning"></i> CNI{% endif %}
                            </div>
                            <div class="small text-truncate">{{ doc.originalName|e }}</div>
                            <a href="{{ asset(doc.path) }}" target="_blank" class="btn btn-sm btn-outline-primary mt-2 w-100">Consulter</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="row g-3">
        <div class="col-md-4">{{ form_row(form.diplomaFile) }}</div>
        <div class="col-md-4">{{ form_row(form.transcriptFile) }}</div>
        <div class="col-md-4">{{ form_row(form.identityFile) }}</div>
    </div>
    <div class="alert alert-info border-0 mt-3 small">Nouveau document remplace l’ancien du même type.</div>
</section>

{# Observations #}
<section class="mb-5">
    <div class="d-flex gap-2 align-items-center mb-3">
        <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle p-2"><i class="bi bi-chat-left-text"></i></div>
        <h3 class="h5 fw-bold mb-0">Observations</h3>
    </div>
    {{ form_row(form.observation, { attr: { rows: 4, placeholder: 'Informations complémentaires...' } }) }}
</section>

{# Actions #}
<div class="border-top pt-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div class="small text-muted"><i class="bi bi-shield-check me-1"></i>Données sécurisées et confidentielles.</div>
    <div class="d-flex gap-2">
        <a href="{{ cancel_path|default(path('equivalence_index')) }}" class="btn btn-light border rounded-pill px-4">
            <i class="bi bi-x-circle me-1"></i> Annuler
        </a>
        <button type="submit" class="btn btn-primary rounded-pill px-5">
            <i class="bi bi-check-circle me-1"></i> {{ button_label|default('Enregistrer') }}
        </button>
    </div>
</div>

{{ form_end(form) }}
