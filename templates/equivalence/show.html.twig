{# templates/equivalence/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Dossier
	{{ equivalence.numeroDossier }}
{% endblock %}

{% block body %}
	{% set statusConfig = {
        'draft': { color: 'secondary', icon: 'pencil-square', label: 'Brouillon' },
        'submitted': { color: 'primary', icon: 'send-check', label: 'Soumis' },
        'in_review': { color: 'warning', icon: 'search', label: 'En analyse' },
        'in_committee': { color: 'info', icon: 'people', label: 'En commission' },
        'approved': { color: 'success', icon: 'check-circle', label: 'Approuvé' },
        'rejected': { color: 'danger', icon: 'x-circle', label: 'Rejeté' }
    } %}
	{% set currentStatus = statusConfig[equivalence.status]|default({
        color: 'secondary',
        icon: 'question-circle',
        label: equivalence.status|replace({'_': ' '})|title
    }) %}

	<div
		class="container-fluid py-4">
		{# ========== HEADER ========== #}
		<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
			<div>
				<div class="d-flex align-items-center gap-3 mb-2">
					<div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
						<i class="bi bi-folder2-open fs-4"></i>
					</div>
					<div>
						<h1 class="h2 fw-bold text-primary mb-1">Dossier n°
							{{ equivalence.numeroDossier|e }}</h1>
						<div class="d-flex flex-wrap gap-2">
							<span class="badge bg-{{ currentStatus.color }} rounded-pill px-3 py-2">
								<i class="bi bi-{{ currentStatus.icon }} me-1"></i>
								{{ currentStatus.label }}
							</span>
							<span class="text-muted small">Créé le
								{{ equivalence.createdAt|date('d/m/Y à H:i') }}</span>
						</div>
					</div>
				</div>
				<p class="text-muted mb-0">Consultation détaillée de la demande d’équivalence académique.</p>
			</div>
			<div class="d-flex flex-wrap gap-2">
				<a href="{{ path('equivalence_index') }}" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
					<i class="bi bi-arrow-left-circle me-1"></i>
					Retour
				</a>
				{% if equivalence.status in ['draft', 'submitted'] %}
					<a href="{{ path('equivalence_edit', { id: equivalence.id }) }}" class="btn btn-primary rounded-pill px-4 shadow-sm">
						<i class="bi bi-pencil-square me-1"></i>
						Modifier
					</a>
				{% endif %}
				<a href="{{ path('equivalence_pdf', { id: equivalence.id }) }}" class="btn btn-danger rounded-pill px-4 shadow-sm">
					<i class="bi bi-file-earmark-pdf me-1"></i>
					PDF
				</a>
			</div>
		</div>

		<div
			class="row g-4">
			{# ========== COLONNE PRINCIPALE ========== #}
			<div class="col-xl-8">
				<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
					<div class="card-header bg-light py-3 border-0">
						<div class="d-flex align-items-center">
							<div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3">
								<i class="bi bi-person-vcard"></i>
							</div>
							<div>
								<h5 class="fw-bold mb-0">Informations du candidat</h5>
								<small class="text-muted">Personnelles et académiques</small>
							</div>
						</div>
					</div>
					<div class="card-body p-4">
						<div
							class="row g-4">
							{# Nom complet #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100 bg-light bg-opacity-50">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-person me-1"></i>Nom complet</small>
									<div class="fw-semibold">{{ equivalence.nom|e }}
										{{ equivalence.prenom|e }}</div>
								</div>
							</div>
							{# Email #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100 bg-light bg-opacity-50">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-envelope me-1"></i>Email</small>
									<div class="fw-semibold">{{ equivalence.email|default('—')|e }}</div>
								</div>
							</div>
							{# Date de naissance #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100 bg-light bg-opacity-50">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-calendar-event me-1"></i>Date de naissance</small>
									<div class="fw-semibold">{{ equivalence.dateNaissance ? equivalence.dateNaissance|date('d/m/Y') : '—' }}</div>
								</div>
							</div>
							{# Lieu de naissance (NOUVEAU) #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100 bg-light bg-opacity-50">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-geo-alt me-1"></i>Lieu de naissance</small>
									<div class="fw-semibold">{{ equivalence.lieuNaissance|default('—')|e }}</div>
								</div>
							</div>
							{# Nationalité #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-globe me-1"></i>Nationalité</small>
									<div class="fw-semibold">{{ equivalence.nationalite ? equivalence.nationalite.nomFrFr|e : '—' }}</div>
								</div>
							</div>
							{# Statut #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-diagram-3 me-1"></i>Statut</small>
									<div>
										<span class="badge bg-{{ currentStatus.color }} rounded-pill px-3 py-2">{{ currentStatus.label }}</span>
									</div>
								</div>
							</div>

							{# ========== SECTION CNI (détaillée) ========== #}
							<div class="col-12">
								<div class="border rounded-4 p-4">
									<div class="d-flex align-items-center mb-3">
										<div class="bg-dark bg-opacity-10 text-dark rounded-circle p-2 me-2">
											<i class="bi bi-card-text"></i>
										</div>
										<h6 class="fw-bold mb-0">Carte Nationale d’Identité (CNI)</h6>
									</div>
									<div class="row g-3">
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Numéro CNI</small>
											<div class="fw-semibold">{{ equivalence.cni|default('—')|split('')|batch(3)|map(b => b|join)|join(' ') }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Date de délivrance</small>
											<div class="fw-semibold">{{ equivalence.cniDateDelivrance ? equivalence.cniDateDelivrance|date('d/m/Y') : '—' }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Lieu de délivrance</small>
											<div class="fw-semibold">{{ equivalence.cniLieuDelivrance|default('—')|e }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Date du duplicata</small>
											<div class="fw-semibold">{{ equivalence.cniDateDuplicata ? equivalence.cniDateDuplicata|date('d/m/Y') : '—' }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Lieu du duplicata</small>
											<div class="fw-semibold">{{ equivalence.cniLieuDuplicata|default('—')|e }}</div>
										</div>
									</div>
								</div>
							</div>

							{# Diplôme de référence (inchangé) #}
							<div class="col-12">
								<div class="border rounded-4 p-4">
									<div class="d-flex align-items-center mb-3">
										<div class="bg-success bg-opacity-10 text-success rounded-circle p-2 me-2">
											<i class="bi bi-mortarboard"></i>
										</div>
										<div>
											<h6 class="fw-bold mb-0">Diplôme de référence</h6>
											<small class="text-muted">Informations académiques</small>
										</div>
									</div>
									<div class="row g-3">
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Diplôme</small>
											<div class="fw-semibold">{{ equivalence.diplomeReference ? equivalence.diplomeReference.titre|e : '—' }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Établissement</small>
											<div class="fw-semibold">{{ equivalence.diplomeReference and equivalence.diplomeReference.etablissement ? equivalence.diplomeReference.etablissement.nom|e : '—' }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Pays</small>
											<div class="fw-semibold">{{ equivalence.diplomeReference and equivalence.diplomeReference.etablissement and equivalence.diplomeReference.etablissement.pays ? equivalence.diplomeReference.etablissement.pays.nomFrFr|e : '—' }}</div>
										</div>
										<div class="col-md-6">
											<small class="text-muted d-block mb-1">Création</small>
											<div class="fw-semibold">{{ equivalence.createdAt|date('d/m/Y H:i') }}</div>
										</div>
									</div>
								</div>
							</div>

							{# Décision et classement attribué #}
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100 bg-success bg-opacity-10 border-success border-opacity-25">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-check-circle me-1"></i>Décision</small>
									<div class="fw-bold text-success">{{ equivalence.decision|default('—')|e }}</div>
								</div>
							</div>
							<div class="col-md-6">
								<div class="border rounded-4 p-3 h-100 bg-info bg-opacity-10 border-info border-opacity-25">
									<small class="text-muted d-block mb-1">
										<i class="bi bi-award me-1"></i>Classement attribué</small>
									<div class="fw-bold text-info">{{ equivalence.classement|default('—')|e }}</div>
								</div>
							</div>

							{# Classement administratif technique #}
							{% if equivalence.cadre or equivalence.echelle %}
								<div class="col-12">
									<div class="border rounded-4 p-4">
										<div class="d-flex align-items-center mb-3">
											<div class="bg-dark bg-opacity-10 text-dark rounded-circle p-2 me-2">
												<i class="bi bi-bar-chart-steps"></i>
											</div>
											<h6 class="fw-bold mb-0">Classement administratif</h6>
										</div>
										<div class="row g-3">
											<div class="col-md-6">
												<small class="text-muted d-block mb-1">Cadre</small>
												<div class="fw-semibold">{{ equivalence.cadre|default('—')|e }}</div>
											</div>
											<div class="col-md-6">
												<small class="text-muted d-block mb-1">Échelle</small>
												<div class="fw-semibold">{{ equivalence.echelle|default('—')|e }}</div>
											</div>
										</div>
										{% if equivalence.classementComplet %}
											<div class="row mt-3">
												<div class="col-12">
													<small class="text-muted d-block mb-1">Classement technique</small>
													<div class="fw-semibold">{{ equivalence.classementComplet|e }}</div>
												</div>
											</div>
										{% endif %}
									</div>
								</div>
							{% endif %}

							{# Observations #}
							{% if equivalence.observation %}
								<div class="col-12">
									<div class="border rounded-4 p-4 bg-light">
										<div class="d-flex align-items-center mb-3">
											<div class="bg-secondary bg-opacity-10 text-secondary rounded-circle p-2 me-2">
												<i class="bi bi-chat-left-text"></i>
											</div>
											<h6 class="fw-bold mb-0">Observations</h6>
										</div>
										<div class="text-dark">{{ equivalence.observation|e|nl2br }}</div>
									</div>
								</div>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

			{# ========== COLONNE LATÉRALE (documents, actions, workflow) – inchangée ========== #}
			<div
				class="col-xl-4">
				{# Documents #}
				<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
					<div class="card-header bg-light py-3 border-0">
						<div class="d-flex align-items-center">
							<div class="bg-warning bg-opacity-10 text-warning rounded-circle p-2 me-2">
								<i class="bi bi-file-earmark-text"></i>
							</div>
							<div>
								<h5 class="fw-bold mb-0">Documents joints</h5>
								<small class="text-muted">Pièces justificatives</small>
							</div>
						</div>
					</div>
					<div class="card-body p-3">
						{% if equivalence.documents|length > 0 %}
							<div class="d-flex flex-column gap-3">
								{% for doc in equivalence.documents %}
									<div class="border rounded-4 p-3">
										<div class="d-flex justify-content-between align-items-start">
											<div class="me-3">
												<div class="fw-semibold mb-1">
													<i class="bi bi-file-earmark-{{ doc.mimeType == 'application/pdf' ? 'pdf' : 'image' }} me-1"></i>
													{{ doc.type|e }}
												</div>
												<small class="text-muted text-break">{{ doc.originalName|e }}</small>
											</div>
											<span class="badge bg-secondary rounded-pill">{{ doc.readableSize }}</span>
										</div>
										<div class="mt-2">
											<a href="{{ asset(doc.path) }}" target="_blank" class="btn btn-sm btn-outline-primary w-100 rounded-3">
												<i class="bi bi-eye me-1"></i>
												Voir
											</a>
										</div>
									</div>
								{% endfor %}
							</div>
						{% else %}
							<div class="text-center py-4">
								<div class="bg-light rounded-circle d-inline-flex p-3 mb-3">
									<i class="bi bi-folder-x text-muted fs-3"></i>
								</div>
								<p class="text-muted mb-0">Aucun document disponible.</p>
							</div>
						{% endif %}
					</div>
				</div>

				{# ========== ACTIONS WORKFLOW (selon statut) ========== #}
				<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
					<div class="card-header bg-light py-3 border-0">
						<div class="d-flex align-items-center">
							<div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-2">
								<i class="bi bi-sliders2"></i>
							</div>
							<div>
								<h5 class="fw-bold mb-0">Actions workflow</h5>
								<small class="text-muted">Changer l’état du dossier</small>
							</div>
						</div>
					</div>
					<div
						class="card-body d-flex flex-column gap-2">
						{# 1. Soumettre (draft → submitted) – accessible à ROLE_AGENT #}
						{% if equivalence.status == 'draft' and is_granted('ROLE_AGENT') %}
							<form method="post" action="{{ path('equivalence_transition', { id: equivalence.id, transition: 'submit' }) }}">
								<input type="hidden" name="_token" value="{{ csrf_token('transition_' ~ equivalence.id) }}">
								<button type="submit" class="btn btn-primary w-100">Soumettre le dossier</button>
							</form>
						{% endif %}

						{# 2. Démarrer l’analyse (submitted → in_review) – commission #}
						{% if equivalence.status == 'submitted' and is_granted('ROLE_COMMISSION') %}
							<form method="post" action="{{ path('equivalence_transition', { id: equivalence.id, transition: 'start_review' }) }}">
								<input type="hidden" name="_token" value="{{ csrf_token('transition_' ~ equivalence.id) }}">
								<button type="submit" class="btn btn-warning w-100">Démarrer l’analyse</button>
							</form>
						{% endif %}

						{# 3. Envoyer au comité (in_review → in_committee) – commission #}
						{% if equivalence.status == 'in_review' and is_granted('ROLE_COMMISSION') %}
							<form method="post" action="{{ path('equivalence_transition', { id: equivalence.id, transition: 'send_to_committee' }) }}">
								<input type="hidden" name="_token" value="{{ csrf_token('transition_' ~ equivalence.id) }}">
								<button type="submit" class="btn btn-info w-100">Envoyer au comité</button>
							</form>
						{% endif %}

						{# 4. Approuver (in_committee → approved) – commission #}
						{% if equivalence.status == 'in_committee' and is_granted('ROLE_COMMISSION') %}
							<form method="post" action="{{ path('equivalence_transition', { id: equivalence.id, transition: 'approve' }) }}" onsubmit="return confirm('Valider définitivement ce dossier ?')">
								<input type="hidden" name="_token" value="{{ csrf_token('transition_' ~ equivalence.id) }}">
								<button type="submit" class="btn btn-success w-100">Approuver</button>
							</form>
						{% endif %}

						{# 5. Rejeter (in_committee → rejected) – commission #}
						{% if equivalence.status == 'in_committee' and is_granted('ROLE_COMMISSION') %}
							<form method="post" action="{{ path('equivalence_transition', { id: equivalence.id, transition: 'reject' }) }}" onsubmit="return confirm('Rejeter ce dossier ?')">
								<input type="hidden" name="_token" value="{{ csrf_token('transition_' ~ equivalence.id) }}">
								<button type="submit" class="btn btn-danger w-100">Rejeter</button>
							</form>
						{% endif %}

						{# 6. Demander modification (in_review ou in_committee → draft) – commission #}
						{% if equivalence.status in ['in_review', 'in_committee'] and is_granted('ROLE_COMMISSION') %}
							<form method="post" action="{{ path('equivalence_transition', { id: equivalence.id, transition: 'ask_modification' }) }}" onsubmit="return confirm('Demander des modifications à l’agent ?')">
								<input type="hidden" name="_token" value="{{ csrf_token('transition_' ~ equivalence.id) }}">
								<button type="submit" class="btn btn-secondary w-100">Demander modification</button>
							</form>
						{% endif %}

						{# 7. Gérer l’arrêté (accessible à l’admin et à la commission) #}
						{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMMISSION') %}
							<div class="mt-2">
								<a href="{{ path('admin_arrete_by_equivalence', { id: equivalence.id }) }}" class="btn btn-danger rounded-pill px-4 shadow-sm w-100">
									<i class="bi bi-file-earmark-pdf me-1"></i>
									Gérer l’arrêté
								</a>
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
