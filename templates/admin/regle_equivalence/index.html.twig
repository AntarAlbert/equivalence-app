{# templates/admin/regle_equivalence/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
    Gestion des règles d'équivalence
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# =========================================================
       HEADER
    ========================================================== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="h2 fw-bold text-primary mb-1">
                <i class="bi bi-diagram-3-fill me-2"></i>
                Règles d'équivalence
            </h1>

            <p class="text-muted mb-0">
                Gestion des classements, catégories, cadres et périodes de validité des diplômes référentiels.
            </p>
        </div>

        <div class="d-flex gap-2">

            <a href="{{ path('admin_diplome_index') }}"
               class="btn btn-light border rounded-pill px-4">
                <i class="bi bi-award me-1"></i>
                Diplômes
            </a>

            <a href="{{ path('admin_regle_equivalence_new') }}"
               class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle me-1"></i>
                Nouvelle règle
            </a>

        </div>

    </div>

    {# =========================================================
       INFORMATIONS
    ========================================================== #}
    <div class="alert alert-primary border-0 shadow-sm rounded-4 mb-4 d-flex align-items-start">

        <i class="bi bi-info-circle-fill fs-4 me-3"></i>

        <div>
            <div class="fw-semibold mb-1">
                Informations importantes
            </div>

            <ul class="mb-0 small">
                <li>
                    Une règle permet de définir le classement administratif d’un diplôme.
                </li>
                <li>
                    Les règles peuvent être limitées dans le temps grâce aux dates de validité.
                </li>
                <li>
                    Une règle inactive n’est jamais prise en compte dans les calculs d’équivalence.
                </li>
            </ul>
        </div>

    </div>

    {# =========================================================
       TABLEAU
    ========================================================== #}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-white border-bottom py-3">

            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-table me-2 text-primary"></i>
                        Liste des règles
                    </h5>
                </div>

                <span class="badge bg-primary rounded-pill px-3 py-2">
                    {{ regles|length }} règle{{ regles|length > 1 ? 's' : '' }}
                </span>

            </div>

        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th class="ps-4">
                                <i class="bi bi-award me-1"></i>
                                Diplôme
                            </th>

                            <th>
                                <i class="bi bi-mortarboard me-1"></i>
                                Classement
                            </th>

                            <th>
                                <i class="bi bi-calendar-range me-1"></i>
                                Période
                            </th>

                            <th>
                                <i class="bi bi-shield-check me-1"></i>
                                Statut
                            </th>

                            <th class="text-end pe-4">
                                <i class="bi bi-gear me-1"></i>
                                Actions
                            </th>
                        </tr>

                    </thead>

                    <tbody>

                        {% for regle in regles %}

                            <tr>

                                {# =========================================================
                                   DIPLOME
                                ========================================================== #}
                                <td class="ps-4">

                                    <div class="fw-semibold text-dark">
                                        {{ regle.diplome ? regle.diplome.titre|e : 'Diplôme supprimé' }}
                                    </div>

                                    {% if regle.diplome and regle.diplome.etablissement %}
                                        <div class="small text-muted mt-1">
                                            <i class="bi bi-building me-1"></i>
                                            {{ regle.diplome.etablissement.nom|e }}
                                        </div>
                                    {% endif %}

                                </td>

                                {# =========================================================
                                   CLASSEMENT
                                ========================================================== #}
                                <td>

                                    <div class="fw-semibold text-primary">
                                        {{ regle.classementComplet|e }}
                                    </div>

                                    <div class="small text-muted mt-1">

                                        <span class="me-2">
                                            <i class="bi bi-diagram-2 me-1"></i>
                                            Cadre :
                                            <strong>{{ regle.cadre.value|e }}</strong>
                                        </span>

                                        <span>
                                            <i class="bi bi-layers me-1"></i>
                                            Échelle :
                                            <strong>{{ regle.echelle.value|e }}</strong>
                                        </span>

                                    </div>

                                </td>

                                {# =========================================================
                                   PERIODE
                                ========================================================== #}
                                <td>

                                    <div class="small">

                                        <div class="mb-1">
                                            <i class="bi bi-calendar-event me-1 text-success"></i>

                                            <strong>Début :</strong>

                                            {{ regle.dateDebut ? regle.dateDebut|date('d/m/Y') : '—' }}
                                        </div>

                                        <div>
                                            <i class="bi bi-calendar-x me-1 text-danger"></i>

                                            <strong>Fin :</strong>

                                            {% if regle.dateFin %}
                                                {{ regle.dateFin|date('d/m/Y') }}
                                            {% else %}
                                                <span class="text-muted">
                                                    Non définie
                                                </span>
                                            {% endif %}
                                        </div>

                                    </div>

                                </td>

                                {# =========================================================
                                   STATUT
                                ========================================================== #}
                                <td>

                                    {% if regle.actif %}

                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">
                                            <i class="bi bi-check-circle-fill me-1"></i>
                                            Active
                                        </span>

                                    {% else %}

                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-2">
                                            <i class="bi bi-pause-circle-fill me-1"></i>
                                            Inactive
                                        </span>

                                    {% endif %}

                                </td>

                                {# =========================================================
                                   ACTIONS
                                ========================================================== #}
                                <td class="text-end pe-4">

                                    <div class="d-inline-flex gap-2">

                                        <a href="{{ path('admin_regle_equivalence_edit', { id: regle.id }) }}"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                           title="Modifier">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <form method="post"
                                              action="{{ path('admin_regle_equivalence_delete', { id: regle.id }) }}"
                                              class="d-inline-block"
                                              onsubmit="return confirm('Confirmer la suppression de cette règle d’équivalence ?');">

                                            <input type="hidden"
                                                   name="_token"
                                                   value="{{ csrf_token('delete_regle_' ~ regle.id) }}">

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                    title="Supprimer">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </form>

                                    </div>

                                </td>

                            </tr>

                        {% else %}

                            <tr>

                                <td colspan="5" class="text-center py-5">

                                    <div class="text-muted">

                                        <i class="bi bi-inbox display-6 d-block mb-3"></i>

                                        <h5 class="fw-semibold">
                                            Aucune règle enregistrée
                                        </h5>

                                        <p class="mb-3">
                                            Commencez par créer une nouvelle règle d’équivalence.
                                        </p>

                                        <a href="{{ path('admin_regle_equivalence_new') }}"
                                           class="btn btn-primary rounded-pill px-4">

                                            <i class="bi bi-plus-circle me-1"></i>
                                            Ajouter une règle

                                        </a>

                                    </div>

                                </td>

                            </tr>

                        {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
{% endblock %}
