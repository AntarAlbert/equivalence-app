{# templates/admin/arrete/form.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ arrete.id ? 'Modifier' : 'Nouvel' }} arrêté{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold text-primary">
                <i class="bi {{ arrete.id ? 'bi-pencil-square' : 'bi-plus-circle-fill' }} me-2"></i>
                {{ arrete.id ? 'Modifier' : 'Créer' }} un arrêté
            </h1>
            <p class="text-muted">Saisie complète de l’arrêté et de ses considérants</p>
        </div>
        <a href="{{ path('admin_arrete_index') }}" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left-circle me-1"></i> Annuler
        </a>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white py-3 px-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-file-text-fill fs-4 me-2"></i>
                <h3 class="h4 mb-0">{{ arrete.id ? 'Modification' : 'Création' }} de l’arrêté</h3>
            </div>
        </div>
        <div class="card-body p-4 p-lg-5">

            {{ form_start(form, { attr: { novalidate: 'novalidate', class: 'needs-validation' } }) }}

            {# ========== INFORMATIONS PRINCIPALES ========== #}
            <div class="row g-4 mb-5">
                {# Le champ numeroArrete a été supprimé – il est auto-généré #}
                <div class="col-md-4">
                    {{ form_row(form.dateArrete, {
                        label_attr: { class: 'form-label fw-semibold' },
                        attr: { class: 'form-control form-control-lg' }
                    }) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.equivalence, {
                        label_attr: { class: 'form-label fw-semibold' },
                        attr: { class: 'form-select form-select-lg' }
                    }) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.titre, {
                        label_attr: { class: 'form-label fw-semibold' },
                        attr: { class: 'form-control form-control-lg', placeholder: 'Titre complet de l’arrêté' }
                    }) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.articleDispositif, {
                        label_attr: { class: 'form-label fw-semibold' },
                        attr: { class: 'form-control', rows: 4, placeholder: 'Texte de l’article dispositif (optionnel)' }
                    }) }}
                </div>
            </div>

            {# ========== CONSIDÉRANTS ========== #}
            <div class="mt-5 pt-3 border-top">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-light rounded-circle p-2 me-2">
                        <i class="bi bi-list-check text-success fs-4"></i>
                    </div>
                    <h4 class="fw-bold text-success mb-0">Considérants</h4>
                    <span class="badge bg-secondary ms-2">Vu que…</span>
                </div>
                <p class="text-muted small mb-3">Chaque « Vu que » représente une base légale ou réglementaire.</p>

                <div id="arrete-considerants-list" data-prototype="{{ form_widget(form.arreteConsiderants.vars.prototype)|e('html_attr') }}">
                    {% for arreteConsiderant in form.arreteConsiderants %}
                        <div class="card shadow-sm mb-4 p-4 bg-light border-0">
                            <div class="row g-3">
                                {{ form_widget(arreteConsiderant) }}
                            </div>
                            <div class="mt-3 d-flex justify-content-end">
                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill remove-considerant">
                                    <i class="bi bi-trash me-1"></i> Supprimer ce considérant
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <button type="button" id="add-considerant" class="btn btn-secondary rounded-pill px-4 mb-3">
                    <i class="bi bi-plus-circle me-1"></i> Ajouter un considérant
                </button>
            </div>

            {# ========== ACTIONS ========== #}
            <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                <a href="{{ path('admin_arrete_index') }}" class="btn btn-light border rounded-pill px-4">
                    <i class="bi bi-x-circle me-1"></i> Annuler
                </a>
                <button type="submit" class="btn btn-primary rounded-pill px-5">
                    <i class="bi bi-check-circle me-1"></i> {{ arrete.id ? 'Mettre à jour' : 'Enregistrer' }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
    (function() {
        function attachRemoveEvent(btn) {
            if (!btn) return;
            btn.addEventListener('click', function() {
                this.closest('.card').remove();
            });
        }

        document.querySelectorAll('.remove-considerant').forEach(attachRemoveEvent);

        const addBtn = document.getElementById('add-considerant');
        const container = document.getElementById('arrete-considerants-list');

        if (addBtn && container) {
            addBtn.addEventListener('click', function() {
                const prototype = container.dataset.prototype;
                const index = container.children.length;
                const newForm = prototype.replace(/__name__/g, index);
                const wrapper = document.createElement('div');
                wrapper.className = 'card shadow-sm mb-4 p-4 bg-light border-0';
                wrapper.innerHTML = `
                    <div class="row g-3">
                        ${newForm}
                    </div>
                    <div class="mt-3 d-flex justify-content-end">
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill remove-considerant">
                            <i class="bi bi-trash me-1"></i> Supprimer ce considérant
                        </button>
                    </div>
                `;
                container.appendChild(wrapper);
                attachRemoveEvent(wrapper.querySelector('.remove-considerant'));
            });
        }
    })();
</script>

<style>
    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid #dee2e6;
        transition: all 0.2s ease;
    }
    .form-control:focus, .form-select:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.15);
    }
    .card {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.07) !important;
    }
    .form-label {
        font-weight: 600;
        color: #1e2a3e;
        margin-bottom: 0.5rem;
    }
    .form-text {
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }
    @media (max-width: 768px) {
        .card-body {
            padding: 1.5rem !important;
        }
    }
</style>
{% endblock %}
