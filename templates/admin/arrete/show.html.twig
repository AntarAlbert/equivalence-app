{# templates/admin/arrete/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
    Arrêté n° {{ arrete.numeroArrete }} – {{ arrete.titre|striptags|slice(0, 60) }}
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ================= HEADER ================= #}
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-4">

            <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-4">

                <div class="d-flex align-items-start gap-3">

                    <div class="bg-danger bg-opacity-10 text-danger rounded-4 p-3 flex-shrink-0">
                        <i class="bi bi-file-earmark-text-fill fs-2"></i>
                    </div>

                    <div>

                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                            <h1 class="h3 fw-bold text-primary mb-0">
                                Arrêté n° {{ arrete.numeroArrete|e }}
                            </h1>

                            {% if arrete.statut is defined %}
                                <span class="badge rounded-pill px-3 py-2
                                    {% if arrete.statut == 'finalise' %}
                                        bg-success-subtle text-success border border-success-subtle
                                    {% else %}
                                        bg-warning-subtle text-warning border border-warning-subtle
                                    {% endif %}">
                                    <i class="bi {% if arrete.statut == 'finalise' %}bi-check-circle{% else %}bi-pencil-square{% endif %} me-1"></i>
                                    {{ arrete.statut == 'finalise' ? 'Finalisé' : 'En cours' }}
                                </span>
                            {% endif %}
                        </div>

                        <p class="text-muted mb-3">
                            {{ arrete.titre|e }}
                        </p>

                        <div class="d-flex flex-wrap gap-2">

                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                <i class="bi bi-calendar-event me-1"></i>
                                {{ arrete.dateArrete|date('d/m/Y') }}
                            </span>

                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                <i class="bi bi-folder2-open me-1"></i>
                                Dossier {{ arrete.equivalence.numeroDossier|e }}
                            </span>

                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                <i class="bi bi-list-check me-1"></i>
                                {{ arrete.considerants|length }} considérant(s)
                            </span>

                        </div>

                    </div>

                </div>

                <div class="d-flex flex-wrap gap-2">

                    <a href="{{ path('admin_arrete_edit', { id: arrete.id }) }}"
                       class="btn btn-warning rounded-pill px-4 shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i>
                        Modifier
                    </a>

                    <a href="{{ path('admin_arrete_pdf', { id: arrete.id }) }}"
                       class="btn btn-danger rounded-pill px-4 shadow-sm">
                        <i class="bi bi-file-earmark-pdf me-1"></i>
                        PDF
                    </a>

                    <a href="{{ path('admin_arrete_index') }}"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left-circle me-1"></i>
                        Retour
                    </a>

                </div>

            </div>

        </div>
    </div>

    {# ================= CONTENT ================= #}
    <div class="row g-4">

        {# ===== LEFT ===== #}
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                            <i class="bi bi-info-circle"></i>
                        </div>
                        <h5 class="fw-bold mb-0">Informations</h5>
                    </div>
                </div>

                <div class="card-body pt-0">

                    <div class="border rounded-4 p-3 mb-3 bg-light-subtle">
                        <small class="text-muted d-block mb-1">
                            <i class="bi bi-hash me-1"></i> Numéro
                        </small>
                        <div class="fw-semibold">
                            {{ arrete.numeroArrete|e }}
                        </div>
                    </div>

                    <div class="border rounded-4 p-3 mb-3 bg-light-subtle">
                        <small class="text-muted d-block mb-1">
                            <i class="bi bi-calendar3 me-1"></i> Date
                        </small>
                        <div class="fw-semibold">
                            {{ arrete.dateArrete|date('d/m/Y') }}
                        </div>
                    </div>

                    <div class="border rounded-4 p-3 mb-3 bg-light-subtle">
                        <small class="text-muted d-block mb-1">
                            <i class="bi bi-folder2-open me-1"></i> Dossier lié
                        </small>

                        <a href="{{ path('equivalence_show', { id: arrete.equivalence.id }) }}"
                           class="text-decoration-none fw-semibold">

                            {{ arrete.equivalence.numeroDossier|e }}

                            {% if arrete.equivalence.nom is defined %}
                                — {{ arrete.equivalence.nom|e }}
                            {% endif %}

                            {% if arrete.equivalence.prenom is defined %}
                                {{ arrete.equivalence.prenom|e }}
                            {% endif %}
                        </a>
                    </div>

                    <div class="border rounded-4 p-3 bg-light-subtle">
                        <small class="text-muted d-block mb-2">
                            <i class="bi bi-text-paragraph me-1"></i>
                            Article dispositif
                        </small>

                        <div class="small text-dark">
                            {{ arrete.articleDispositif|default('—')|nl2br }}
                        </div>
                    </div>

                </div>

            </div>

        </div>

        {# ===== RIGHT ===== #}
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0 py-3">

                    <div class="d-flex justify-content-between align-items-center">

                        <div class="d-flex align-items-center gap-2">
                            <div class="bg-success bg-opacity-10 text-success rounded-3 p-2">
                                <i class="bi bi-list-ul"></i>
                            </div>

                            <h5 class="fw-bold mb-0">
                                Considérants
                            </h5>
                        </div>

                        <span class="badge bg-secondary rounded-pill">
                            {{ arrete.considerants|length }}
                        </span>

                    </div>

                </div>

                <div class="card-body p-0">

                    {% if arrete.considerants|length > 0 %}

                        <div class="list-group list-group-flush">

                            {% for considerant in arrete.considerants|sort((a,b)=> a.ordre <=> b.ordre) %}

                                <div class="list-group-item border-0 border-bottom p-4">

                                    <div class="d-flex gap-3">

                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle bg-secondary text-white fw-bold d-flex align-items-center justify-content-center"
                                                 style="width:34px;height:34px;">
                                                {{ loop.index }}
                                            </div>
                                        </div>

                                        <div class="flex-grow-1">

                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">

                                                <span class="badge bg-light text-dark border">
                                                    {{ considerant.type|upper|e }}
                                                </span>

                                                <span class="fw-semibold">
                                                    {{ considerant.reference|e }}
                                                </span>

                                                {% if considerant.date %}
                                                    <small class="text-muted">
                                                        <i class="bi bi-calendar-event me-1"></i>
                                                        {{ considerant.date|date('d/m/Y') }}
                                                    </small>
                                                {% endif %}

                                            </div>

                                            <div class="text-secondary mb-2">
                                                {{ considerant.portant|e }}
                                            </div>

                                            {% if considerant.extrait %}
                                                <div class="bg-light rounded-4 p-3 small text-muted border">
                                                    <i class="bi bi-chat-left-quote me-1"></i>
                                                    {{ considerant.extrait|striptags|slice(0, 220)|e }}
                                                    {% if considerant.extrait|length > 220 %}…{% endif %}
                                                </div>
                                            {% endif %}

                                        </div>

                                    </div>

                                </div>

                            {% endfor %}

                        </div>

                    {% else %}

                        <div class="text-center py-5">
                            <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                            <p class="text-muted mb-0">
                                Aucun considérant enregistré.
                            </p>
                        </div>

                    {% endif %}

                </div>

            </div>

        </div>

    </div>

    {# ================= FOOTER ================= #}
    <div class="text-center small text-muted mt-4 border-top pt-3">

        <i class="bi bi-clock-history me-1"></i>

        Créé le {{ arrete.createdAt|date('d/m/Y à H:i') }}

        {% if arrete.updatedAt %}
            — Modifié le {{ arrete.updatedAt|date('d/m/Y à H:i') }}
        {% endif %}

    </div>

</div>

<style>
    .card {
        transition: all .18s ease;
    }

    .card:hover {
        transform: translateY(-2px);
    }

    .list-group-item:hover {
        background: rgba(13,110,253,.02);
    }

    @media (max-width: 768px) {
        .display-responsive {
            font-size: 1.3rem;
        }
    }
</style>
{% endblock %}
