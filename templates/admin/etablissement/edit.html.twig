{# templates/admin/etablissement/edit.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    Modifier {{ etablissement.nom|e }}
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# =========================================================
       HEADER
    ========================================================== #}
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3 mb-4">

        <div>

            <div class="d-flex align-items-center gap-2 mb-2">

                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill">

                    <i class="bi bi-building me-1"></i>
                    Établissement

                </span>

                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">

                    <i class="bi bi-hash me-1"></i>
                    ID {{ etablissement.id }}

                </span>

            </div>

            <h1 class="h2 fw-bold text-primary mb-1">

                <i class="bi bi-pencil-square me-2"></i>
                Modifier l’établissement

            </h1>

            <p class="text-muted mb-0">

                Mise à jour des informations administratives
                de l’établissement référencé.

            </p>

        </div>

        <div class="d-flex flex-wrap gap-2">

            <a href="{{ path('admin_etablissement_index') }}"
               class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">

                <i class="bi bi-arrow-left me-1"></i>
                Retour à la liste

            </a>

        </div>

    </div>

    {# =========================================================
       CARTE PRINCIPALE
    ========================================================== #}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        {# =========================================================
           HEADER CARTE
        ========================================================== #}
        <div class="card-header bg-light border-0 py-4">

            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">

                <div>

                    <h2 class="h4 fw-bold text-dark mb-2">

                        <i class="bi bi-building-fill text-primary me-2"></i>
                        {{ etablissement.nom|e }}

                    </h2>

                    <div class="d-flex flex-wrap align-items-center gap-3 small text-muted">

                        {% if etablissement.pays %}

                            <span>

                                <i class="bi bi-globe-europe-africa me-1"></i>
                                {{ etablissement.pays.nomFrFr|e }}

                            </span>

                        {% endif %}

                        {% if etablissement.ville %}

                            <span>

                                <i class="bi bi-geo-alt me-1"></i>
                                {{ etablissement.ville|e }}

                            </span>

                        {% endif %}

                        {% if etablissement.type %}

                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">

                                {{ etablissement.type|e }}

                            </span>

                        {% endif %}

                    </div>

                </div>

                <div class="text-lg-end">

                    <div class="small text-muted mb-1">
                        Diplômes associés
                    </div>

                    <div class="display-6 fw-bold text-primary">

                        {{ etablissement.diplomes|length }}

                    </div>

                </div>

            </div>

        </div>

        {# =========================================================
           BODY
        ========================================================== #}
        <div class="card-body p-4 p-lg-5">

            {# =========================================================
               ALERTE INFORMATION
            ========================================================== #}
            <div class="alert alert-light border shadow-sm rounded-4 d-flex align-items-start gap-3 mb-4">

                <div class="flex-shrink-0">

                    <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 48px; height: 48px;">

                        <i class="bi bi-shield-check fs-4 text-success"></i>

                    </div>

                </div>

                <div>

                    <div class="fw-semibold mb-1">
                        Mise à jour sécurisée
                    </div>

                    <div class="small text-muted">

                        Vérifiez attentivement les informations avant validation.
                        Les modifications seront automatiquement répercutées
                        sur les diplômes liés à cet établissement.

                    </div>

                </div>

            </div>

            {# =========================================================
               FORMULAIRE
            ========================================================== #}
            <div class="border rounded-4 p-3 p-md-4 bg-body-tertiary bg-opacity-25">

                {% include 'admin/etablissement/_form.html.twig' %}

            </div>

        </div>

    </div>

    {# =========================================================
       STATISTIQUES RAPIDES
    ========================================================== #}
    <div class="row g-4 mt-1">

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex align-items-center gap-3">

                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 52px; height: 52px;">

                            <i class="bi bi-mortarboard fs-4 text-primary"></i>

                        </div>

                        <div>

                            <div class="small text-muted">
                                Diplômes associés
                            </div>

                            <div class="h4 fw-bold mb-0">
                                {{ etablissement.diplomes|length }}
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex align-items-center gap-3">

                        <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 52px; height: 52px;">

                            <i class="bi bi-globe fs-4 text-success"></i>

                        </div>

                        <div>

                            <div class="small text-muted">
                                Pays
                            </div>

                            <div class="fw-semibold">

                                {{ etablissement.pays ? etablissement.pays.nomFrFr|e : 'Non défini' }}

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex align-items-center gap-3">

                        <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 52px; height: 52px;">

                            <i class="bi bi-geo-alt fs-4 text-warning"></i>

                        </div>

                        <div>

                            <div class="small text-muted">
                                Ville
                            </div>

                            <div class="fw-semibold">

                                {{ etablissement.ville|default('Non renseignée')|e }}

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    {# =========================================================
       ZONE SENSIBLE
    ========================================================== #}
    {% if is_granted('ROLE_SUPER_ADMIN') %}

        <div class="card border-danger shadow-sm rounded-4 mt-4 overflow-hidden">

            <div class="card-header bg-danger bg-opacity-10 border-danger py-3">

                <h3 class="h6 fw-bold text-danger mb-0">

                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Zone sensible

                </h3>

            </div>

            <div class="card-body p-4">

                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">

                    <div>

                        <div class="fw-semibold text-danger mb-1">
                            Suppression définitive
                        </div>

                        <div class="small text-muted">

                            Cette action est irréversible.
                            La suppression peut affecter les diplômes
                            et les règles d’équivalence liés à cet établissement.

                        </div>

                    </div>

                    <form method="post"
                          action="{{ path('admin_etablissement_delete', { id: etablissement.id }) }}"
                          onsubmit="return confirm('Confirmez-vous la suppression définitive de cet établissement ?');">

                        <input type="hidden"
                               name="_token"
                               value="{{ csrf_token('delete' ~ etablissement.id) }}">

                        <button type="submit"
                                class="btn btn-outline-danger rounded-pill px-4 shadow-sm">

                            <i class="bi bi-trash me-1"></i>
                            Supprimer l’établissement

                        </button>

                    </form>

                </div>

            </div>

        </div>

    {% endif %}

</div>
{% endblock %}
