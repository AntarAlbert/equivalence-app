{{ form_start(form) }}

<div class="row g-4">

    <div class="col-md-12">
        {{ form_label(form.nom, null, {
            label_attr: { class: 'form-label fw-semibold' }
        }) }}

        {{ form_widget(form.nom, {
            attr: {
                class: 'form-control',
                placeholder: 'Nom de l’établissement'
            }
        }) }}

        <div class="text-danger small">
            {{ form_errors(form.nom) }}
        </div>
    </div>

    <div class="col-md-6">
        {{ form_label(form.pays, null, {
            label_attr: { class: 'form-label fw-semibold' }
        }) }}

        {{ form_widget(form.pays, {
            attr: { class: 'form-select' }
        }) }}

        <div class="text-danger small">
            {{ form_errors(form.pays) }}
        </div>
    </div>

    <div class="col-md-6">
        {{ form_label(form.ville, null, {
            label_attr: { class: 'form-label fw-semibold' }
        }) }}

        {{ form_widget(form.ville, {
            attr: {
                class: 'form-control',
                placeholder: 'Ville'
            }
        }) }}

        <div class="text-danger small">
            {{ form_errors(form.ville) }}
        </div>
    </div>

    <div class="col-md-12">
        {{ form_label(form.type, null, {
            label_attr: { class: 'form-label fw-semibold' }
        }) }}

        {{ form_widget(form.type, {
            attr: {
                class: 'form-control',
                placeholder: 'Université, École, Institut...'
            }
        }) }}

        <div class="text-danger small">
            {{ form_errors(form.type) }}
        </div>
    </div>

</div>

<div class="d-flex justify-content-end gap-2 mt-4">

    <a href="{{ path('admin_etablissement_index') }}"
       class="btn btn-light border rounded-pill px-4">
        Annuler
    </a>

    <button class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-save"></i>
        Enregistrer
    </button>

</div>

{{ form_end(form) }}
