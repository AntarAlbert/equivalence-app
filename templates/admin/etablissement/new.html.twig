{# templates/admin/etablissement/new.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    Nouvel établissement
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# =========================================================
       HEADER
    ========================================================== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>

            <h1 class="h2 fw-bold text-primary mb-1">
                <i class="bi bi-building-add me-2"></i>
                Nouvel établissement
            </h1>

            <p class="text-muted mb-0">
                Création d’un établissement académique dans le référentiel.
            </p>

        </div>

        <div class="d-flex flex-wrap gap-2">

            <a href="{{ path('admin_etablissement_index') }}"
               class="btn btn-outline-secondary rounded-pill px-4">

                <i class="bi bi-arrow-left me-1"></i>
                Retour à la liste

            </a>

        </div>

    </div>

    {# =========================================================
       FORMULAIRE
    ========================================================== #}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-light border-0 py-3">

            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-info-circle me-2 text-primary"></i>
                Informations de l’établissement
            </h5>

        </div>

        <div class="card-body p-4">

            <div class="row">

                <div class="col-xl-9">

                    {% include 'admin/etablissement/_form.html.twig' %}

                </div>

                <div class="col-xl-3 mt-4 mt-xl-0">

                    <div class="card border-0 bg-light rounded-4 h-100">

                        <div class="card-body">

                            <h6 class="fw-bold mb-3">
                                <i class="bi bi-shield-check me-2 text-success"></i>
                                Recommandations
                            </h6>

                            <ul class="small text-muted ps-3 mb-0">

                                <li class="mb-2">
                                    Vérifiez l’orthographe officielle de l’établissement.
                                </li>

                                <li class="mb-2">
                                    Associez le bon pays afin d’assurer la cohérence du référentiel.
                                </li>

                                <li class="mb-2">
                                    Évitez les doublons avant la création.
                                </li>

                                <li>
                                    Les diplômes seront automatiquement liés à cet établissement.
                                </li>

                            </ul>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
{% endblock %}
