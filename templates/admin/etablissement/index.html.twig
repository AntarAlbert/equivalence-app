{# templates/admin/etablissement/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    Gestion des établissements
{% endblock %}

{% block body %}

<div class="container-fluid py-4">

    {# =========================================================
       HEADER
    ========================================================== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="h2 fw-bold text-primary mb-1">
                <i class="bi bi-buildings-fill me-2"></i>
                Établissements
            </h1>

            <p class="text-muted mb-0">
                Gestion des universités, écoles, instituts et centres de formation.
            </p>
        </div>

        <a href="{{ path('admin_etablissement_new') }}"
           class="btn btn-primary rounded-pill px-4 shadow-sm">

            <i class="bi bi-plus-circle me-1"></i>
            Nouvel établissement

        </a>

    </div>

    {# =========================================================
       STATS
    ========================================================== #}
    <div class="row g-3 mb-4">

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="small text-uppercase text-muted fw-semibold">
                                Établissements
                            </div>

                            <div class="display-6 fw-bold text-primary">
                                {{ stats.total }}
                            </div>
                        </div>

                        <div class="icon-circle bg-primary-subtle text-primary">
                            <i class="bi bi-building fs-3"></i>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="small text-uppercase text-muted fw-semibold">
                                Pays représentés
                            </div>

                            <div class="display-6 fw-bold text-success">
                                {{ stats.pays }}
                            </div>
                        </div>

                        <div class="icon-circle bg-success-subtle text-success">
                            <i class="bi bi-globe-europe-africa fs-3"></i>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="small text-uppercase text-muted fw-semibold">
                                Diplômes liés
                            </div>

                            <div class="display-6 fw-bold text-info">
                                {{ stats.diplomes }}
                            </div>
                        </div>

                        <div class="icon-circle bg-info-subtle text-info">
                            <i class="bi bi-mortarboard-fill fs-3"></i>
                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>

    {# =========================================================
       FILTRES
    ========================================================== #}
    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-body">

            <form method="get"
                  action="{{ path('admin_etablissement_index') }}"
                  class="row g-3 align-items-end">

                <div class="col-lg-6">

                    <label class="form-label fw-semibold small">
                        Recherche
                    </label>

                    <div class="input-group">

                        <span class="input-group-text bg-light">
                            <i class="bi bi-search"></i>
                        </span>

                        <input type="text"
                               name="search"
                               value="{{ search }}"
                               class="form-control"
                               placeholder="Nom, ville, type, pays...">

                    </div>

                </div>

                <div class="col-lg-3">

                    <label class="form-label fw-semibold small">
                        Pays
                    </label>

                    <select name="pays" class="form-select">

                        <option value="">
                            Tous les pays
                        </option>

                        {% for pays in paysList %}

                            <option value="{{ pays.id }}"
                                {{ currentPays == pays.id ? 'selected' }}>
                                {{ pays.nomFrFr }}
                            </option>

                        {% endfor %}

                    </select>

                </div>

                <div class="col-lg-3">

                    <div class="d-flex gap-2">

                        <button class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i>
                            Filtrer
                        </button>

                        <a href="{{ path('admin_etablissement_index') }}"
                           class="btn btn-outline-secondary w-100">

                            <i class="bi bi-arrow-repeat me-1"></i>
                            Reset

                        </a>

                    </div>

                </div>

            </form>

        </div>

    </div>

    {# =========================================================
       TABLEAU
    ========================================================== #}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-light border-0 py-3">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h5 class="fw-semibold mb-1">
                        <i class="bi bi-table me-2 text-primary"></i>
                        Référentiel des établissements
                    </h5>

                    <div class="small text-muted">
                        Liste des établissements académiques.
                    </div>

                </div>

                <span class="badge bg-primary-subtle text-primary border rounded-pill px-3 py-2">
                    {{ etablissements|length }}
                    établissement{{ etablissements|length > 1 ? 's' : '' }}
                </span>

            </div>

        </div>

        <div class="card-body p-0">

            {% if etablissements|length > 0 %}

                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">

                            <tr>
                                <th class="ps-4">Établissement</th>
                                <th>Pays</th>
                                <th>Ville</th>
                                <th>Type</th>
                                <th class="text-center">Diplômes</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                            {% for etablissement in etablissements %}

                                <tr>

                                    <td class="ps-4">

                                        <div class="fw-semibold">
                                            {{ etablissement.nom }}
                                        </div>

                                        <div class="small text-muted">
                                            ID #{{ etablissement.id }}
                                        </div>

                                    </td>

                                    <td>

                                        {% if etablissement.pays %}

                                            <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                                {{ etablissement.pays.nomFrFr }}
                                            </span>

                                        {% else %}
                                            —
                                        {% endif %}

                                    </td>

                                    <td>
                                        {{ etablissement.ville ?: '—' }}
                                    </td>

                                    <td>
                                        {{ etablissement.type ?: '—' }}
                                    </td>

                                    <td class="text-center">

                                        <span class="badge bg-secondary rounded-pill px-3 py-2">
                                            {{ etablissement.diplomes|length }}
                                        </span>

                                    </td>

                                    <td class="text-end pe-4">

                                        <div class="d-inline-flex gap-2">

                                            <a href="{{ path('admin_etablissement_edit', { id: etablissement.id }) }}"
                                               class="btn btn-sm btn-outline-primary rounded-pill">

                                                <i class="bi bi-pencil-square"></i>

                                            </a>

                                            {% if is_granted('ROLE_SUPER_ADMIN') %}

                                                <form method="post"
                                                      action="{{ path('admin_etablissement_delete', { id: etablissement.id }) }}"
                                                      class="d-inline-block"
                                                      onsubmit="return confirm('Supprimer cet établissement ?');">

                                                    <input type="hidden"
                                                           name="_token"
                                                           value="{{ csrf_token('delete_etablissement_' ~ etablissement.id) }}">

                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger rounded-pill">

                                                        <i class="bi bi-trash"></i>

                                                    </button>

                                                </form>

                                            {% endif %}

                                        </div>

                                    </td>

                                </tr>

                            {% endfor %}

                        </tbody>

                    </table>

                </div>

            {% else %}

                <div class="text-center py-5">

                    <i class="bi bi-inbox display-4 text-muted d-block mb-3"></i>

                    <h4 class="fw-semibold">
                        Aucun établissement trouvé
                    </h4>

                    <p class="text-muted">
                        Aucun résultat ne correspond aux filtres.
                    </p>

                </div>

            {% endif %}

        </div>

    </div>

</div>

<style>

    .icon-circle{
        width:60px;
        height:60px;
        border-radius:50%;
        display:flex;
        align-items:center;
        justify-content:center;
    }

    .table > :not(caption) > * > *{
        vertical-align:middle;
    }

    .table-hover tbody tr:hover{
        background:rgba(13,110,253,.03);
    }

</style>

{% endblock %}
