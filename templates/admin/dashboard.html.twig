{# templates/admin/dashboard.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
Administration
{% endblock %}

{% block body %}

<div class="container-fluid py-4">

    {# ===================== EN-TÊTE ===================== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="h2 fw-bold text-primary mb-1">
                <i class="bi bi-shield-lock-fill me-2"></i>
                Administration
            </h1>

            <p class="text-muted mb-0">
                Tableau de bord de gestion et de supervision de la plateforme.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">

            <a
                href="{{ path('admin_users') }}"
                class="btn btn-primary"
            >
                <i class="bi bi-people-fill me-1"></i>
                Utilisateurs
            </a>

            <a
                href="{{ path('admin_statistics') }}"
                class="btn btn-outline-primary"
            >
                <i class="bi bi-bar-chart-fill me-1"></i>
                Statistiques
            </a>

            <a
                href="{{ path('admin_logs') }}"
                class="btn btn-outline-dark"
            >
                <i class="bi bi-journal-text me-1"></i>
                Journaux système
            </a>

        </div>

    </div>

    {# ===================== STATISTIQUES ===================== #}
    <div class="row g-4 mb-4">

        <div class="col-xl-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Utilisateurs
                            </div>

                            <div class="display-6 fw-bold text-primary">
                                {{ totalUsers }}
                            </div>

                        </div>

                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                            <i class="bi bi-people-fill fs-4"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Administrateurs
                            </div>

                            <div class="display-6 fw-bold text-danger">
                                {{ totalAdmins }}
                            </div>

                        </div>

                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3">
                            <i class="bi bi-shield-fill-check fs-4"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Agents
                            </div>

                            <div class="display-6 fw-bold text-warning">
                                {{ totalAgents }}
                            </div>

                        </div>

                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3">
                            <i class="bi bi-person-workspace fs-4"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <div class="text-muted small text-uppercase fw-semibold mb-2">
                                Commission
                            </div>

                            <div class="display-6 fw-bold text-success">
                                {{ totalCommission }}
                            </div>

                        </div>

                        <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                            <i class="bi bi-person-check-fill fs-4"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="row g-4">

        {# ===================== DERNIERS UTILISATEURS ===================== #}
        <div class="col-xl-8">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-header bg-white border-0 py-3 px-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <h2 class="h5 fw-bold mb-1">
                                <i class="bi bi-clock-history text-primary me-2"></i>
                                Derniers utilisateurs enregistrés
                            </h2>

                            <p class="text-muted small mb-0">
                                Liste des comptes récemment créés sur la plateforme.
                            </p>

                        </div>

                        <a
                            href="{{ path('admin_users') }}"
                            class="btn btn-sm btn-outline-primary"
                        >
                            <i class="bi bi-eye me-1"></i>
                            Voir tout
                        </a>

                    </div>

                </div>

                <div class="card-body p-0">

                    {% if latestUsers is not empty %}

                        <div class="table-responsive">

                            <table class="table align-middle mb-0">

                                <thead class="table-light">

                                    <tr>
                                        <th class="ps-4">Utilisateur</th>
                                        <th>Rôles</th>
                                        <th>Date création</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    {% for user in latestUsers %}

                                        <tr>

                                            <td class="ps-4">

                                                <div class="fw-semibold text-dark">
                                                    {{ user.email|e }}
                                                </div>

                                            </td>

                                            <td>

                                                {% for role in user.roles %}

                                                    {% set badgeColor = 'secondary' %}

                                                    {% if role == 'ROLE_ADMIN' %}
                                                        {% set badgeColor = 'danger' %}
                                                    {% elseif role == 'ROLE_AGENT' %}
                                                        {% set badgeColor = 'warning' %}
                                                    {% elseif role == 'ROLE_COMMISSION' %}
                                                        {% set badgeColor = 'success' %}
                                                    {% endif %}

                                                    <span class="badge bg-{{ badgeColor }} me-1">
                                                        {{ role|replace({'ROLE_': ''})|title }}
                                                    </span>

                                                {% endfor %}

                                            </td>

                                            <td>

                                                {% if user.createdAt is defined and user.createdAt %}
                                                    {{ user.createdAt|date('d/m/Y H:i') }}
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}

                                            </td>

                                        </tr>

                                    {% endfor %}

                                </tbody>

                            </table>

                        </div>

                    {% else %}

                        <div class="p-5 text-center text-muted">

                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>

                            Aucun utilisateur récent.

                        </div>

                    {% endif %}

                </div>

            </div>

        </div>

        {# ===================== ACCÈS RAPIDE ===================== #}
        <div class="col-xl-4">

            <div class="card border-0 shadow-sm rounded-4 mb-4">

                <div class="card-header bg-light border-0 py-3">

                    <h2 class="h5 fw-bold mb-0">
                        <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                        Accès rapide
                    </h2>

                </div>

                <div class="card-body d-grid gap-3">

                    <a
                        href="{{ path('admin_user_new') }}"
                        class="btn btn-primary"
                    >
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Créer un utilisateur
                    </a>

                    <a
                        href="{{ path('admin_users') }}"
                        class="btn btn-outline-primary"
                    >
                        <i class="bi bi-people me-2"></i>
                        Gérer les utilisateurs
                    </a>

                    <a
                        href="{{ path('admin_statistics') }}"
                        class="btn btn-outline-success"
                    >
                        <i class="bi bi-graph-up-arrow me-2"></i>
                        Consulter les statistiques
                    </a>

                    <a
                        href="{{ path('admin_logs') }}"
                        class="btn btn-outline-dark"
                    >
                        <i class="bi bi-file-earmark-text me-2"></i>
                        Consulter les journaux
                    </a>

                </div>

            </div>

            {# ===================== INFORMATIONS ===================== #}
            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-light border-0 py-3">

                    <h2 class="h5 fw-bold mb-0">
                        <i class="bi bi-info-circle-fill text-primary me-2"></i>
                        Informations système
                    </h2>

                </div>

                <div class="card-body">

                    <div class="mb-4">

                        <div class="fw-semibold mb-1">
                            <i class="bi bi-shield-lock me-1 text-success"></i>
                            Sécurité
                        </div>

                        <p class="small text-muted mb-0">
                            Toutes les opérations administratives sont protégées
                            par contrôle d'accès et validation sécurisée.
                        </p>

                    </div>

                    <hr>

                    <div class="mb-4">

                        <div class="fw-semibold mb-1">
                            <i class="bi bi-activity me-1 text-primary"></i>
                            Supervision
                        </div>

                        <p class="small text-muted mb-0">
                            Les activités importantes sont enregistrées dans les
                            journaux système pour assurer la traçabilité.
                        </p>

                    </div>

                    <hr>

                    <div>

                        <div class="fw-semibold mb-1">
                            <i class="bi bi-database-check me-1 text-warning"></i>
                            Administration centralisée
                        </div>

                        <p class="small text-muted mb-0">
                            Gérez les comptes utilisateurs, les rôles et le suivi
                            des opérations depuis un espace sécurisé unique.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
