{# templates/admin/diplome/new.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    Nouveau diplôme
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# =========================================================
       HEADER
    ========================================================== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>

            <h1 class="h2 fw-bold text-primary mb-1">
                <i class="bi bi-journal-bookmark-fill me-2"></i>
                Nouveau diplôme
            </h1>

            <p class="text-muted mb-0">
                Ajouter un diplôme au référentiel officiel
            </p>

        </div>

        <a href="{{ path('admin_diplome_index') }}"
           class="btn btn-outline-secondary rounded-pill px-4">

            <i class="bi bi-arrow-left me-1"></i>
            Retour

        </a>

    </div>

    {# =========================================================
       FORMULAIRE
    ========================================================== #}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-light py-3">

            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-info-circle me-2 text-primary"></i>
                Informations du diplôme
            </h5>

        </div>

        <div class="card-body p-4">

            {{ form_start(form, {
                attr: {
                    novalidate: 'novalidate',
                    autocomplete: 'off',
                    class: 'needs-validation'
                }
            }) }}

            <div class="row g-4">

                {# =====================================================
                   TITRE
                ====================================================== #}
                <div class="col-md-6">

                    {{ form_label(form.titre, null, {
                        label_attr: {
                            class: 'form-label fw-semibold'
                        }
                    }) }}

                    <div class="input-group">

                        <span class="input-group-text bg-light">
                            <i class="bi bi-award"></i>
                        </span>

                        {{ form_widget(form.titre, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Ex : Master en Informatique'
                            }
                        }) }}

                    </div>

                    {% if form_errors(form.titre) %}
                        <div class="text-danger small mt-1">
                            {{ form_errors(form.titre) }}
                        </div>
                    {% endif %}

                </div>

                {# =====================================================
                   ETABLISSEMENT
                ====================================================== #}
                <div class="col-md-6">

                    {{ form_label(form.etablissement, null, {
                        label_attr: {
                            class: 'form-label fw-semibold'
                        }
                    }) }}

                    <div class="input-group">

                        <span class="input-group-text bg-light">
                            <i class="bi bi-building"></i>
                        </span>

                        {{ form_widget(form.etablissement, {
                            attr: {
                                class: 'form-select'
                            }
                        }) }}

                    </div>

                    <div class="form-text">
                        Université ou établissement délivrant le diplôme.
                    </div>

                    {% if form_errors(form.etablissement) %}
                        <div class="text-danger small mt-1">
                            {{ form_errors(form.etablissement) }}
                        </div>
                    {% endif %}

                </div>

                {# =====================================================
                   ORGANISME HISTORIQUE
                ====================================================== #}
                <div class="col-12">

                    {{ form_label(form.organisme, null, {
                        label_attr: {
                            class: 'form-label fw-semibold'
                        }
                    }) }}

                    <div class="input-group">

                        <span class="input-group-text bg-light">
                            <i class="bi bi-bank"></i>
                        </span>

                        {{ form_widget(form.organisme, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Ancien organisme ou établissement historique'
                            }
                        }) }}

                    </div>

                    <div class="form-text">
                        Champ historique facultatif utilisé pour compatibilité avec les anciens dossiers.
                    </div>

                    {% if form_errors(form.organisme) %}
                        <div class="text-danger small mt-1">
                            {{ form_errors(form.organisme) }}
                        </div>
                    {% endif %}

                </div>

            </div>

            {# =========================================================
               INFORMATION
            ========================================================== #}
            <div class="alert alert-info border-0 rounded-4 mt-4">

                <div class="d-flex align-items-start">

                    <div class="me-3 fs-4">
                        <i class="bi bi-info-circle-fill"></i>
                    </div>

                    <div>

                        <strong>Gestion des équivalences</strong>

                        <div class="mt-1">
                            Les informations de classement
                            (cadre, échelle, catégorie, bonification)
                            sont désormais gérées séparément
                            via les règles d’équivalence afin
                            de conserver un historique complet.
                        </div>

                    </div>

                </div>

            </div>

            {# =========================================================
               ACTIONS
            ========================================================== #}
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">

                <a href="{{ path('admin_diplome_index') }}"
                   class="btn btn-light border rounded-pill px-4">

                    <i class="bi bi-x-circle me-1"></i>
                    Annuler

                </a>

                <button type="submit"
                        class="btn btn-primary rounded-pill px-4">

                    <i class="bi bi-save me-1"></i>
                    Enregistrer

                </button>

            </div>

            {{ form_end(form) }}

        </div>

    </div>

</div>
{% endblock %}
