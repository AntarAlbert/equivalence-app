{# templates/admin/diplome/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
	Diplômes référentiels
{% endblock %}

{% block body %}

	<div
		class="container-fluid py-4">

		{# =========================================================
		       HEADER
		    ========================================================== #}
		<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

			<div>

				<h1 class="h3 fw-bold text-primary mb-1">
					<i class="bi bi-award-fill me-2"></i>
					Diplômes référentiels
				</h1>

				<p class="text-muted mb-0">
					Administration du référentiel académique.
				</p>

			</div>

			<div>

				<a href="{{ path('admin_diplome_new') }}" class="btn btn-primary rounded-pill px-4">

					<i class="bi bi-plus-circle me-1"></i>
					Nouveau diplôme

				</a>

			</div>

		</div>

		{# =========================================================
		       STATS
		    ========================================================== #}
		<div class="row g-3 mb-4">

			<div class="col-md-4">

				<div class="card border-0 shadow-sm rounded-4 h-100">

					<div class="card-body py-3">

						<div class="d-flex justify-content-between align-items-center">

							<div>

								<div class="small text-muted text-uppercase fw-semibold">
									Diplômes
								</div>

								<div class="fs-2 fw-bold text-primary">
									{{ stats.totalDiplomes }}
								</div>

							</div>

							<div class="icon-circle bg-primary-subtle text-primary">
								<i class="bi bi-award fs-4"></i>
							</div>

						</div>

					</div>

				</div>

			</div>

			<div class="col-md-4">

				<div class="card border-0 shadow-sm rounded-4 h-100">

					<div class="card-body py-3">

						<div class="d-flex justify-content-between align-items-center">

							<div>

								<div class="small text-muted text-uppercase fw-semibold">
									Établissements
								</div>

								<div class="fs-2 fw-bold text-success">
									{{ stats.totalEtablissements }}
								</div>

							</div>

							<div class="icon-circle bg-success-subtle text-success">
								<i class="bi bi-building fs-4"></i>
							</div>

						</div>

					</div>

				</div>

			</div>

			<div class="col-md-4">

				<div class="card border-0 shadow-sm rounded-4 h-100">

					<div class="card-body py-3">

						<div class="d-flex justify-content-between align-items-center">

							<div>

								<div class="small text-muted text-uppercase fw-semibold">
									Pays
								</div>

								<div class="fs-2 fw-bold text-info">
									{{ stats.totalPays }}
								</div>

							</div>

							<div class="icon-circle bg-info-subtle text-info">
								<i class="bi bi-globe-europe-africa fs-4"></i>
							</div>

						</div>

					</div>

				</div>

			</div>

		</div>

		{# =========================================================
		       FILTRES
		    ========================================================== #}
		<div class="card border-0 shadow-sm rounded-4 mb-4">

			<div class="card-body p-4">

				<form method="get" action="{{ path('admin_diplome_index') }}">

					<div class="row g-3 align-items-end">

						<div class="col-lg-7">

							<label class="form-label small fw-semibold text-secondary">
								<i class="bi bi-search me-1"></i>
								Recherche
							</label>

							<div class="input-group">

								<span class="input-group-text bg-light border-end-0">
									<i class="bi bi-search text-muted"></i>
								</span>

								<input type="text" name="search" class="form-control border-start-0" value="{{ search|default('') }}" placeholder="Diplôme, organisme, établissement, ville...">

							</div>

						</div>

						<div class="col-lg-3">

							<label class="form-label small fw-semibold text-secondary">
								<i class="bi bi-globe2 me-1"></i>
								Pays
							</label>

							<select name="pays" class="form-select">

								<option value="">
									Tous les pays
								</option>

								{% for pays in paysList %}

									<option value="{{ pays.id }}" {{ currentPays == pays.id ? 'selected' : '' }}>

										{{ pays.nomFrFr|e }}

									</option>

								{% endfor %}

							</select>

						</div>

						<div class="col-lg-2">

							<div class="d-grid gap-2">

								<button type="submit" class="btn btn-primary">

									<i class="bi bi-filter-circle me-1"></i>
									Filtrer

								</button>

								<a href="{{ path('admin_diplome_index') }}" class="btn btn-outline-secondary">

									Réinitialiser

								</a>

							</div>

						</div>

					</div>

				</form>

			</div>

		</div>

		{# =========================================================
		       TABLEAU
		    ========================================================== #}
		<div class="card border-0 shadow-sm rounded-4 overflow-hidden">

			<div class="card-header bg-white border-0 py-3 px-4">

				<div class="d-flex justify-content-between align-items-center">

					<div>

						<h2 class="h5 fw-bold mb-1">
							<i class="bi bi-table me-2 text-primary"></i>
							Liste des diplômes
						</h2>

						<div class="small text-muted">
							Référentiel académique centralisé.
						</div>

					</div>

					<span class="badge bg-primary-subtle text-primary border rounded-pill px-3 py-2">
						{{ diplomes.getTotalItemCount }}
						résultat{{ diplomes.getTotalItemCount > 1 ? 's' : '' }}
					</span>

				</div>

			</div>

			{% if diplomes|length > 0 %}

				<div class="table-responsive">

					<table class="table table-hover align-middle mb-0">

						<thead class="table-light">

							<tr>

								<th class="ps-4">
									Diplôme
								</th>

								<th>
									Établissement
								</th>

								<th>
									Pays
								</th>

								<th class="text-center">
									Règles
								</th>

								<th class="text-end pe-4">
									Actions
								</th>

							</tr>

						</thead>

						<tbody>

							{% for diplome in diplomes %}

								<tr>

									<td class="ps-4">

										<div class="d-flex align-items-start gap-3">

											<div class="icon-small bg-primary-subtle text-primary">
												<i class="bi bi-mortarboard-fill"></i>
											</div>

											<div>

												<div class="fw-semibold text-dark">
													{{ diplome.titre|e }}
												</div>

												{% if diplome.organisme %}
													<div class="small text-muted mt-1">
														{{ diplome.organisme|e }}
													</div>
												{% endif %}

											</div>

										</div>

									</td>

									<td>

										{% if diplome.etablissement %}

											<div class="fw-semibold">
												{{ diplome.etablissement.nom|e }}
											</div>

											{% if diplome.etablissement.ville %}
												<div class="small text-muted">
													<i class="bi bi-geo-alt me-1"></i>
													{{ diplome.etablissement.ville|e }}
												</div>
											{% endif %}

										{% else %}

											<span class="text-muted">—</span>

										{% endif %}

									</td>

									<td>

										{% if diplome.etablissement and diplome.etablissement.pays %}

											<span class="badge bg-light text-dark border rounded-pill px-3 py-2">
												<i class="bi bi-globe2 me-1"></i>
												{{ diplome.etablissement.pays.nomFrFr|e }}
											</span>

										{% else %}

											<span class="text-muted">—</span>

										{% endif %}

									</td>

									<td class="text-center">

										<span class="badge bg-primary rounded-pill px-3 py-2">
											{{ diplome.reglesEquivalence|length }}
										</span>

									</td>

									<td class="text-end pe-4">

										<div class="btn-group">

											<a href="{{ path('admin_diplome_show', {id: diplome.id}) }}" class="btn btn-sm btn-outline-primary" title="Consulter">

												<i class="bi bi-eye"></i>

											</a>

											<a href="{{ path('admin_diplome_edit', {id: diplome.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">

												<i class="bi bi-pencil-square"></i>

											</a>

											{% if is_granted('ROLE_SUPER_ADMIN') %}

												<form method="post" action="{{ path('admin_diplome_delete', {id: diplome.id}) }}" class="d-inline-block" onsubmit="return confirm('Supprimer ce diplôme ?');">

													<input type="hidden" name="_token" value="{{ csrf_token('delete_diplome_' ~ diplome.id) }}">

													<button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">

														<i class="bi bi-trash"></i>

													</button>

												</form>

											{% endif %}

										</div>

									</td>

								</tr>

							{% endfor %}

						</tbody>

					</table>

				</div>

				<div class="card-footer bg-white border-0 py-3">

					<div class="d-flex justify-content-center">
						{{ knp_pagination_render(diplomes) }}
					</div>

				</div>

			{% else %}

				<div class="text-center py-5 px-4">

					<div class="mb-3">
						<i class="bi bi-inbox display-4 text-muted"></i>
					</div>

					<h4 class="fw-semibold mb-2">
						Aucun diplôme trouvé
					</h4>

					<p class="text-muted mb-4">
						Aucun diplôme ne correspond aux critères de recherche.
					</p>

					<a href="{{ path('admin_diplome_new') }}" class="btn btn-primary rounded-pill px-4">

						<i class="bi bi-plus-circle me-1"></i>
						Ajouter un diplôme

					</a>

				</div>

			{% endif %}

		</div>

	</div>

	<style>

		.icon-circle {
			width: 58px;
			height: 58px;
			border-radius: 50%;
			display: inline-flex;
			align-items: center;
			justify-content: center;
		}

		.icon-small {
			width: 46px;
			height: 46px;
			border-radius: 50%;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
		}

		.table >:not(caption) > * > * {
			vertical-align: middle;
		}

		.table-hover tbody tr:hover {
			background: rgba(13, 110, 253, .03);
		}
	</style>

{% endblock %}
