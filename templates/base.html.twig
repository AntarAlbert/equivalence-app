<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <meta name="referrer" content="strict-origin-when-cross-origin">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta http-equiv="X-Frame-Options" content="DENY">
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <title>{% block title %}Système d'Équivalence{% endblock %}</title>

    <!-- Bootstrap 5 + Icons + Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --success: #16a34a;
            --danger: #dc2626;
            --warning: #f59e0b;
            --bg: #f4f7fb;
            --surface: #ffffff;
            --border: #e5e7eb;
            --text: #111827;
            --text-muted: #6b7280;
            --sidebar-width: 290px;
            --topbar-height: 74px;
        }

        * { font-family: 'Inter', sans-serif; }
        body { background: var(--bg); color: var(--text); min-height: 100vh; }
        a { text-decoration: none; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 999px; }

        /* Topbar */
        .topbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: var(--topbar-height);
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            z-index: 1200;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            font-weight: 800;
            color: var(--primary);
        }
        .brand-icon {
            width: 42px; height: 42px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary), #60a5fa);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(37,99,235,.22);
        }
        .menu-toggle {
            border: none;
            background: transparent;
            color: var(--primary);
            font-size: 1.6rem;
            display: none;
        }
        .user-button {
            border-radius: 999px !important;
            padding: 0.5rem 1rem !important;
            background: #fff !important;
            border: 1px solid var(--border) !important;
            font-weight: 600 !important;
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            top: var(--topbar-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--topbar-height));
            background: var(--surface);
            border-right: 1px solid var(--border);
            padding: 1.2rem;
            overflow-y: auto;
            z-index: 1100;
            transition: transform .25s ease;
        }
        .sidebar-section {
            margin-top: 1.5rem;
            margin-bottom: 0.7rem;
            padding-left: 0.5rem;
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #9ca3af;
        }
        .sidebar .nav-link {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            padding: 0.8rem 1rem;
            margin-bottom: 0.25rem;
            border-radius: 16px;
            font-weight: 500;
            color: var(--text-muted);
            transition: .2s;
        }
        .sidebar .nav-link i { font-size: 1rem; }
        .sidebar .nav-link:hover {
            background: rgba(37,99,235,.08);
            color: var(--primary);
        }
        .sidebar .nav-link.active {
            background: linear-gradient(135deg, var(--primary), #3b82f6);
            color: #fff;
            box-shadow: 0 12px 30px rgba(37,99,235,.22);
        }

        /* Submenu */
        .submenu-wrapper { margin-bottom: 0.5rem; }
        .submenu-toggle::after {
            content: '\F285';
            font-family: bootstrap-icons;
            margin-left: auto;
            font-size: 0.8rem;
            transition: transform .2s;
        }
        .submenu-toggle[aria-expanded="true"]::after { transform: rotate(90deg); }
        .sidebar-submenu {
            margin-top: 0.35rem;
            margin-left: 0.8rem;
            padding-left: 0.8rem;
            border-left: 2px solid #e0ecff;
        }
        .sidebar-submenu .nav-link {
            font-size: 0.92rem;
            padding: 0.6rem 0.9rem;
            border-radius: 14px;
        }
        .sidebar-submenu .nav-link.active {
            background: rgba(37,99,235,.10);
            color: var(--primary);
            box-shadow: none;
        }

        /* Main content */
        .main-content {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            min-height: calc(100vh - var(--topbar-height));
            padding: 2rem;
        }

        /* Responsive */
        @media (max-width: 991px) {
            .menu-toggle { display: inline-flex; }
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); box-shadow: 0 20px 40px rgba(0,0,0,.18); }
            .main-content { margin-left: 0; padding: 1.2rem; }
            .sidebar-overlay {
                position: fixed;
                inset: 0;
                background: rgba(15,23,42,.45);
                z-index: 1050;
                display: none;
            }
            .sidebar-overlay.show { display: block; }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

{% set current_route = app.request.attributes.get('_route') %}
{% set referentiel_open = current_route starts with 'admin_diplome_' or current_route starts with 'admin_etablissement_' or current_route starts with 'admin_regle_equivalence_' %}

{# ===== TOPBAR ===== #}
<nav class="navbar topbar px-4">
    <div class="container-fluid p-0">
        <div class="d-flex align-items-center gap-3">
            <button class="menu-toggle" id="sidebarToggle" type="button" aria-label="Menu">
                <i class="bi bi-list"></i>
            </button>
            <a href="{{ path('equivalence_index') }}" class="brand">
                <div class="brand-icon"><i class="bi bi-mortarboard-fill"></i></div>
                <div class="d-none d-md-block">
                    <span>Equivalence SI</span>
                    <small class="text-muted d-block" style="font-size: .7rem;">Plateforme de gestion</small>
                </div>
            </a>
        </div>

        {% if app.user %}
        <div class="dropdown">
            <button class="btn user-button dropdown-toggle" data-bs-toggle="dropdown" type="button">
                <i class="bi bi-person-circle me-1"></i> {{ app.user.email|e }}
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 p-2">
                <li class="px-3 py-2">
                    <div class="fw-semibold">{{ app.user.email|e }}</div>
                    <small class="text-muted">{{ app.user.roles|join(', ')|e }}</small>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item rounded-3 text-danger" href="{{ path('app_logout') }}">
                        <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
                    </a>
                </li>
            </ul>
        </div>
        {% endif %}
    </div>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

{# ===== SIDEBAR ===== #}
<aside class="sidebar" id="sidebar">
    <ul class="nav flex-column">

        {# ========== SECTION COMMUNE ========== #}
        <li class="sidebar-section">Navigation</li>
        <li class="nav-item">
            <a href="{{ path('equivalence_index') }}" class="nav-link {{ current_route == 'equivalence_index' ? 'active' : '' }}">
                <i class="bi bi-speedometer2"></i> Tableau de bord
            </a>
        </li>

        {# ========== CANDIDAT ========== #}
        {% if is_granted('ROLE_CANDIDAT') %}
            <li class="nav-item">
                <a href="{{ path('equivalence_new') }}" class="nav-link {{ current_route == 'equivalence_new' ? 'active' : '' }}">
                    <i class="bi bi-folder-plus"></i> Nouveau dossier
                </a>
            </li>
        {% endif %}

        {# ========== ÉTABLISSEMENT ========== #}
        {% if is_granted('ROLE_ETABLISSEMENT') %}
            <li class="sidebar-section">Établissement</li>
            <li class="nav-item">
                <a href="{{ path('etablissement_diplome_index') }}" class="nav-link {{ current_route starts with 'etablissement_diplome_' ? 'active' : '' }}">
                    <i class="bi bi-award"></i> Diplômes proposés
                </a>
            </li>
        {% endif %}

        {# ========== COMMISSION ========== #}
        {% if is_granted('ROLE_COMMISSION') %}
            <li class="sidebar-section">Commission</li>
            <li class="nav-item">
                <a href="{{ path('commission_dashboard') }}" class="nav-link {{ current_route starts with 'commission_' ? 'active' : '' }}">
                    <i class="bi bi-clipboard-check"></i> Dossiers
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('commission_diplome_index') }}" class="nav-link {{ current_route starts with 'commission_diplome_' ? 'active' : '' }}">
                    <i class="bi bi-patch-check"></i> Validation diplômes
                </a>
            </li>
        {% endif %}

        {# ========== AGENT ========== #}
        {% if is_granted('ROLE_AGENT') and not is_granted('ROLE_ADMIN') %}
            {# L'agent voit seulement les dossiers (déjà dans le tableau de bord) #}
            {# Pas de section spécifique #}
        {% endif %}

        {# ========== ADMIN ========== #}
        {% if is_granted('ROLE_ADMIN') %}
            <li class="sidebar-section">Référentiels</li>
            <li class="nav-item submenu-wrapper">
                <a class="nav-link submenu-toggle {{ referentiel_open ? 'active' : '' }}" data-bs-toggle="collapse" href="#referentielMenu" role="button" aria-expanded="{{ referentiel_open ? 'true' : 'false' }}">
                    <i class="bi bi-journal-bookmark"></i> Diplômes référentiels
                </a>
                <div class="collapse {{ referentiel_open ? 'show' : '' }}" id="referentielMenu">
                    <div class="sidebar-submenu">
                        <a href="{{ path('admin_diplome_index') }}" class="nav-link {{ current_route starts with 'admin_diplome_' ? 'active' : '' }}">
                            <i class="bi bi-award"></i> Diplômes
                        </a>
                        <a href="{{ path('admin_regle_equivalence_index') }}" class="nav-link {{ current_route starts with 'admin_regle_equivalence_' ? 'active' : '' }}">
                            <i class="bi bi-diagram-3"></i> Règles d'équivalence
                        </a>
                        <a href="{{ path('admin_etablissement_index') }}" class="nav-link {{ current_route starts with 'admin_etablissement_' ? 'active' : '' }}">
                            <i class="bi bi-building"></i> Établissements
                        </a>
                        <a href="{{ path('admin_arrete_index') }}" class="nav-link {{ current_route starts with 'admin_arrete_' ? 'active' : '' }}">
                            <i class="bi bi-file-earmark-text"></i> Arrêtés
                        </a>
                    </div>
                </div>
            </li>

            <li class="sidebar-section">Administration</li>
            <li class="nav-item">
                <a href="{{ path('admin_dashboard') }}" class="nav-link {{ current_route == 'admin_dashboard' ? 'active' : '' }}">
                    <i class="bi bi-shield-lock"></i> Administration
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('admin_users') }}" class="nav-link {{ current_route == 'admin_users' ? 'active' : '' }}">
                    <i class="bi bi-people-fill"></i> Utilisateurs
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('admin_statistics') }}" class="nav-link {{ current_route == 'admin_statistics' ? 'active' : '' }}">
                    <i class="bi bi-bar-chart-line"></i> Statistiques
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('admin_logs') }}" class="nav-link {{ current_route == 'admin_logs' ? 'active' : '' }}">
                    <i class="bi bi-clock-history"></i> Journaux
                </a>
            </li>
        {% endif %}
    </ul>
</aside>

{# ===== MAIN CONTENT ===== #}
<main class="main-content">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }} alert-dismissible fade show mb-4" role="alert">
                <div class="d-flex align-items-center">
                    <i class="bi bi-{{ label == 'danger' ? 'exclamation-triangle-fill' : (label == 'warning' ? 'exclamation-circle-fill' : 'check-circle-fill') }} me-2"></i>
                    <span>{{ message|e }}</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script>
    (function() {
        const sidebar = document.getElementById('sidebar');
        const toggle = document.getElementById('sidebarToggle');
        const overlay = document.getElementById('sidebarOverlay');

        if (toggle) {
            toggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('show');
            });
        }
        if (overlay) {
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
            });
        }
        document.querySelectorAll('.sidebar .nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                if (window.innerWidth <= 991) {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('show');
                }
            });
        });
    })();
</script>
{% block javascripts %}{% endblock %}
</body>
</html>
