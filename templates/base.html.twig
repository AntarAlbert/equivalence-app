{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">

		<meta name="viewport" content="width=device-width, initial-scale=1">

		<meta name="robots" content="noindex,nofollow">
		<meta name="referrer" content="strict-origin-when-cross-origin">

		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta http-equiv="X-Frame-Options" content="DENY">
		<meta http-equiv="X-Content-Type-Options" content="nosniff">

		<title>
			{% block title %}
				Système d'Équivalence
			{% endblock %}
		</title>

		{# =========================================================
		       CSS
		    ========================================================= #}

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">

		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous">

		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

		<style>:root
		{
			--primary-color: #0d6efd;
			--primary-hover: #0b5ed7;
			--secondary-color: #6c757d;
			--light-bg: #f5f7fb;
			--sidebar-width: 270px;
			--navbar-height: 70px;
			--border-color: #e9ecef;
			--text-color: #495057;
		}

		* {
			font-family: 'Inter', sans-serif;
		}

		html,
		body {
			margin: 0;
			padding: 0;
			overflow-x: hidden;
			background: var(--light-bg);
		}

		body {
			min-height: 100vh;
		}

		a {
			text-decoration: none;
		}

		/* =========================================================
           NAVBAR
        ========================================================= */

		.top-navbar {
			height: var(--navbar-height);
			background: #fff;
			border-bottom: 1px solid var(--border-color);
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 1100;
			backdrop-filter: blur(8px);
		}

		.brand-logo {
			display: flex;
			align-items: center;
			gap: 0.6rem;
			font-weight: 700;
			font-size: 1.05rem;
			color: var(--primary-color);
		}

		.brand-logo:hover {
			color: var(--primary-hover);
		}

		.sidebar-toggle {
			display: none;
			background: transparent;
			border: none;
			font-size: 1.5rem;
			color: var(--primary-color);
			cursor: pointer;
		}

		/* =========================================================
           SIDEBAR
        ========================================================= */

		.sidebar {
			width: var(--sidebar-width);
			height: calc(100vh - var(--navbar-height));
			position: fixed;
			top: var(--navbar-height);
			left: 0;
			background: #fff;
			border-right: 1px solid var(--border-color);
			overflow-y: auto;
			overflow-x: hidden;
			padding: 1rem;
			z-index: 1040;
			transition: transform 0.25s ease;
		}

		.sidebar-section-title {
			font-size: 0.72rem;
			font-weight: 700;
			color: #adb5bd;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			margin: 1.5rem 0 0.75rem;
			padding-left: 0.5rem;
		}

		.sidebar .nav-link {
			display: flex;
			align-items: center;
			border-radius: 14px;
			padding: 0.85rem 1rem;
			margin-bottom: 0.35rem;
			color: var(--text-color);
			font-weight: 500;
			transition: 0.2s ease;
		}

		.sidebar .nav-link i {
			margin-right: 0.8rem;
			font-size: 1rem;
			min-width: 20px;
		}

		.sidebar .nav-link:hover {
			background: rgba(13, 110, 253, .08);
			color: var(--primary-color);
		}

		.sidebar .nav-link.active {
			background: var(--primary-color);
			color: #fff;
			box-shadow: 0 10px 24px rgba(13, 110, 253, .18);
		}

		/* =========================================================
           SUBMENU
        ========================================================= */

		.submenu-wrapper {
			margin-bottom: 0.5rem;
		}

		.submenu-toggle {
			cursor: pointer;
		}

		.submenu-toggle::after {
			content: '\F282';
			font-family: bootstrap-icons;
			margin-left: auto;
			transition: transform 0.2s ease;
			font-size: 0.85rem;
		}

		.submenu-toggle[aria-expanded="true"]::after {
			transform: rotate(90deg);
		}

		.sidebar-submenu {
			margin-top: 0.35rem;
			margin-left: 0.6rem;
			padding-left: 0.9rem;
			border-left: 2px solid #e9f0ff;
		}

		.sidebar-submenu .nav-link {
			padding: 0.72rem 0.9rem;
			font-size: 0.93rem;
			border-radius: 12px;
			margin-bottom: 0.2rem;
		}

		.sidebar-submenu .nav-link.active {
			background: rgba(13, 110, 253, .12);
			color: var(--primary-color);
			box-shadow: none;
			font-weight: 600;
		}

		/* =========================================================
           MAIN CONTENT
        ========================================================= */

		.main-content {
			margin-left: var(--sidebar-width);
			margin-top: var(--navbar-height);
			padding: 2rem;
			min-height: calc(100vh - var(--navbar-height));
		}

		/* =========================================================
           ALERTS
        ========================================================= */

		.custom-alert {
			border: none;
			border-radius: 18px;
			box-shadow: 0 8px 24px rgba(0, 0, 0, .06);
		}

		/* =========================================================
           SCROLLBAR
        ========================================================= */

		.sidebar::-webkit-scrollbar {
			width: 8px;
		}

		.sidebar::-webkit-scrollbar-thumb {
			background: #dce3ea;
			border-radius: 50px;
		}

		/* =========================================================
           MOBILE
        ========================================================= */

		@media(max-width: 991px) {

			.sidebar-toggle {
				display: inline-flex;
			}

			.sidebar {
				transform: translateX(-100%);
				box-shadow: none;
			}

			.sidebar.open {
				transform: translateX(0);
				box-shadow: 0 0 30px rgba(0, 0, 0, .12);
			}

			.main-content {
				margin-left: 0;
				padding: 1.25rem;
			}

			.sidebar-overlay {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, .35);
				z-index: 1030;
				display: none;
			}

			.sidebar-overlay.show {
				display: block;
			}
		}
	</style>

	{% block stylesheets %}{% endblock %}
</head>

<body>

	<nav class="navbar top-navbar px-4">

		<div class="container-fluid p-0">

			<div class="d-flex align-items-center gap-3">

				<button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Ouvrir le menu">
					<i class="bi bi-list"></i>
				</button>

				<a href="{{ path('equivalence_index') }}" class="brand-logo">

					<i class="bi bi-mortarboard-fill"></i>

					<span>Equivalence SI</span>

				</a>

			</div>

			<div class="d-flex align-items-center gap-3">

				{% if app.user %}

					<div class="dropdown">

						<button class="btn btn-light border rounded-pill px-3 dropdown-toggle" data-bs-toggle="dropdown" type="button" aria-expanded="false">

							<i class="bi bi-person-circle"></i>

							{{ app.user.email|e }}

						</button>

						<ul class="dropdown-menu dropdown-menu-end shadow border-0">

							<li>
								<span class="dropdown-item-text small text-muted">
									{{ app.user.roles|join(', ')|e }}
								</span>
							</li>

							<li>
								<hr class="dropdown-divider">
							</li>

							<li>

								<a class="dropdown-item text-danger" href="{{ path('app_logout') }}">

									<i class="bi bi-box-arrow-right"></i>

									Déconnexion

								</a>

							</li>

						</ul>

					</div>

				{% endif %}

			</div>

		</div>

	</nav>

	<div class="sidebar-overlay" id="sidebarOverlay"></div>

	{% set current_route = app.request.attributes.get('_route') %}

	{% set referentiel_open =
    current_route starts with 'admin_diplome_'
    or current_route starts with 'admin_etablissement_'
    or current_route starts with 'admin_regle_equivalence_'
%}

	<aside class="sidebar" id="sidebar">

		<ul class="nav flex-column">

			<li class="sidebar-section-title">
				Navigation
			</li>
			{% if is_granted('ROLE_CANDIDAT') %}
				<li class="nav-item">
					<a class="nav-link" href="{{ path('equivalence_index') }}">Mes dossiers</a>
				</li>
			{% endif %}

			{% if is_granted('ROLE_ETABLISSEMENT') %}
				<li class="nav-item dropdown">
					<a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">Établissement</a>
					<ul class="dropdown-menu">
						<li>
							<a class="dropdown-item" href="{{ path('etablissement_diplome_index') }}">Diplômes proposés</a>
						</li>
						<li>
							<a class="dropdown-item" href="{{ path('etablissement_diplome_obtenu_index') }}">Listes des diplômés</a>
						</li>
					</ul>
				</li>
			{% endif %}

			{% if is_granted('ROLE_COMMISSION') %}
				<li class="nav-item dropdown">
					<a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">Commission</a>
					<ul class="dropdown-menu">
						<li>
							<a class="dropdown-item" href="{{ path('commission_diplome_index') }}">Valider diplômes</a>
						</li>
						<li>
							<a class="dropdown-item" href="{{ path('commission_dashboard') }}">Dossiers équivalence</a>
						</li>
					</ul>
				</li>
			{% endif %}
			<li class="nav-item">

				<a href="{{ path('equivalence_index') }}" class="nav-link {{ current_route == 'equivalence_index' ? 'active' : '' }}">

					<i class="bi bi-speedometer2"></i>

					Tableau de bord

				</a>

			</li>

			{% if is_granted('ROLE_AGENT') %}

				<li class="nav-item">

					<a href="{{ path('equivalence_new') }}" class="nav-link {{ current_route == 'equivalence_new' ? 'active' : '' }}">

						<i class="bi bi-folder-plus"></i>

						Nouveau dossier

					</a>

				</li>

			{% endif %}

			{% if is_granted('ROLE_ADMIN') %}

				<li class="sidebar-section-title">
					Référentiels
				</li>

				<li class="nav-item submenu-wrapper">

					<a class="nav-link submenu-toggle {{ referentiel_open ? 'active' : '' }}" data-bs-toggle="collapse" href="#referentielMenu" role="button" aria-expanded="{{ referentiel_open ? 'true' : 'false' }}" aria-controls="referentielMenu">

						<i class="bi bi-book"></i>

						Diplômes référentiels

					</a>

					<div class="collapse {{ referentiel_open ? 'show' : '' }}" id="referentielMenu">

						<div class="sidebar-submenu">

							<a href="{{ path('admin_diplome_index') }}" class="nav-link {{ current_route starts with 'admin_diplome_' ? 'active' : '' }}">

								<i class="bi bi-award"></i>

								Diplômes

							</a>

							<a href="{{ path('admin_regle_equivalence_index') }}" class="nav-link {{ current_route starts with 'admin_regle_equivalence_' ? 'active' : '' }}">

								<i class="bi bi-calendar-range"></i>

								Règles d'équivalence

							</a>

							<a href="{{ path('admin_etablissement_index') }}" class="nav-link {{ current_route starts with 'admin_etablissement_' ? 'active' : '' }}">

								<i class="bi bi-building"></i>

								Établissements

							</a>

						</div>

					</div>

				</li>

			{% endif %}

			{% if is_granted('ROLE_COMMISSION') %}

				<li class="sidebar-section-title">
					Commission
				</li>

				<li class="nav-item">

					<a href="{{ path('commission_dashboard') }}" class="nav-link {{ current_route starts with 'commission_' ? 'active' : '' }}">

						<i class="bi bi-people"></i>

						Commission

					</a>

				</li>

			{% endif %}
			{% if is_granted('ROLE_ADMIN') %}
				<li class="nav-item">
					<a href="{{ path('admin_arrete_index') }}" class="nav-link {{ current_route starts with 'admin_arrete_' ? 'active' : '' }}">
						<i class="bi bi-file-text"></i>
						Arrêtés
					</a>
				</li>
			{% endif %}

			{% if is_granted('ROLE_ADMIN') %}

				<li class="sidebar-section-title">
					Administration
				</li>

				<li class="nav-item">

					<a href="{{ path('admin_dashboard') }}" class="nav-link {{ current_route == 'admin_dashboard' ? 'active' : '' }}">

						<i class="bi bi-shield-lock"></i>

						Administration

					</a>

				</li>

				<li class="nav-item">

					<a href="{{ path('admin_users') }}" class="nav-link {{ current_route == 'admin_users' ? 'active' : '' }}">

						<i class="bi bi-people-fill"></i>

						Utilisateurs

					</a>

				</li>

				<li class="nav-item">

					<a href="{{ path('admin_statistics') }}" class="nav-link {{ current_route == 'admin_statistics' ? 'active' : '' }}">

						<i class="bi bi-bar-chart"></i>

						Statistiques

					</a>

				</li>

				<li class="nav-item">

					<a href="{{ path('admin_logs') }}" class="nav-link {{ current_route == 'admin_logs' ? 'active' : '' }}">

						<i class="bi bi-clock-history"></i>

						Journal système

					</a>

				</li>

			{% endif %}

		</ul>

	</aside>

	<main class="main-content">

		{% for label, messages in app.flashes %}

			{% for message in messages %}

				<div class="alert alert-{{ label|e }} alert-dismissible fade show custom-alert">

					{{ message|e }}

					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>

				</div>

			{% endfor %}

		{% endfor %}

		{% block body %}{% endblock %}

	</main>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

	<script>
		(() => {

'use strict';

const sidebar = document.getElementById('sidebar');
const sidebarToggle = document.getElementById('sidebarToggle');
const overlay = document.getElementById('sidebarOverlay');

function closeSidebar() {
sidebar.classList.remove('open');
overlay.classList.remove('show');
}

function openSidebar() {
sidebar.classList.add('open');
overlay.classList.add('show');
}

if (sidebarToggle) {

sidebarToggle.addEventListener('click', () => {

if (sidebar.classList.contains('open')) {
closeSidebar();
} else {
openSidebar();
}

});

}

if (overlay) {
overlay.addEventListener('click', closeSidebar);
}

document.querySelectorAll('.sidebar a').forEach(link => {

link.addEventListener('click', () => {

if (window.innerWidth <= 991) {
closeSidebar();
}

});

});

})();
	</script>

	{% block javascripts %}{% endblock %}

</body></html>
